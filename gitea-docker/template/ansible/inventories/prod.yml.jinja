# {{ project_name }} - Production Inventory
# Usage: ansible-playbook site.yml -i inventories/prod.yml

all:
  children:
    gitea:
      hosts:
        {{ project_name }}:
          ansible_host: {{ droplet_ip }}
          ansible_user: ubuntu
          ansible_ssh_private_key_file: ~/.ssh/{{ project_name }}_id_ed25519
          app_dir: /opt/{{ project_name | replace('-', '_') }}
          domain: {{ domain }}
          gitea_image: gitea/gitea:1.24
          caddy_image: reg.mini.dev/caddy:2
          postgres_version: "16"
