# {{ project_name }} - Gitea Role
# Gitea-specific configuration

- name: Create Gitea data directory
  ansible.builtin.file:
    path: "{{ app_dir }}/data"
    state: directory
    mode: '0755'
    owner: ubuntu
    group: ubuntu

- name: Create TLS directory
  ansible.builtin.file:
    path: "{{ app_dir }}/tls"
    state: directory
    mode: '0755'
    owner: ubuntu
    group: ubuntu

- name: Check if Gitea container exists
  community.docker.docker_container_info:
    name: "{{ project_name }}-gitea-1"
  register: gitea_container

- name: Pull Gitea image
  community.docker.docker_image:
    name: "{{ gitea_image }}"
    source: pull
  when: gitea_container is not defined or gitea_container.container is none

- name: Ensure compose file is present
  ansible.builtin.copy:
    dest: "{{ app_dir }}/compose.yaml"
    content: |
      # This file is managed by the deploy script - manual changes will be overwritten
      # See scripts/deploy.sh for the authoritative compose configuration
    mode: '0644'
  when: false  # Managed by deploy script

- name: Check Gitea health
  when: gitea_container.container is defined and gitea_container.container != none
  block:
    - name: Get Gitea container status
      community.docker.docker_container_info:
        name: "{{ project_name }}-gitea-1"
      register: gitea_status

    - name: Restart Gitea if unhealthy
      when: gitea_status.container is defined and gitea_status.container.State.Health.Status != "healthy"
      ansible.builtin.shell: |
        cd {{ app_dir }} && docker compose restart gitea
      changed_when: true
