# {{ project_name }} - Production Environment Variables
# ⚠️ CRITICAL: Never commit .env.prod with real values
# Use Infisical to manage production secrets

# Domain
DOMAIN={{ domain }}

# Container Images
GITEA_IMAGE=gitea/gitea:1.24
CADDY_IMAGE=reg.mini.dev/caddy:2
POSTGRES_VERSION=16

# Database
DB_NAME=gitea
DB_USER=gitea
DB_PASSWORD=<GET_FROM_INFISICAL>
DB_ROOT_PASSWORD=<GET_FROM_INFISICAL>

# Gitea security secrets
GITEA__security__SECRET_KEY=<GET_FROM_INFISICAL>
GITEA__security__INTERNAL_TOKEN=<GET_FROM_INFISICAL>
GITEA__oauth2__JWT_SECRET=<GET_FROM_INFISICAL>

# Infisical
ENABLE_INFISICAL=true
INFISICAL_TOKEN=<GET_FROM_INFISICAL>
INFISICAL_PROJECT_ID=<GET_FROM_INFISICAL>
INFISICAL_ENVIRONMENT=prod
