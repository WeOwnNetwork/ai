# Formbricks — copy to .env and fill secrets (never commit .env).
# Generate hex secrets: openssl rand -hex 32
# Prefer scripts/deploy.sh which creates .env on the droplet only.

WEBAPP_URL=https://forms.weown.tools
NEXTAUTH_URL=https://forms.weown.tools

# Postgres (must match DATABASE_URL user/password/db)
POSTGRES_USER=formbricks
POSTGRES_PASSWORD=<GENERATE_WITH_openssl_rand_-hex_24>
POSTGRES_DB=formbricks
DATABASE_URL=postgresql://formbricks:<POSTGRES_PASSWORD>@postgres:5432/formbricks?sslmode=disable

REDIS_URL=redis://redis:6379

# Required Formbricks secrets (openssl rand -hex 32 each)
NEXTAUTH_SECRET=<GENERATE_WITH_openssl_rand_-hex_32>
ENCRYPTION_KEY=<GENERATE_WITH_openssl_rand_-hex_32>
CRON_SECRET=<GENERATE_WITH_openssl_rand_-hex_32>
HUB_API_KEY=<GENERATE_WITH_openssl_rand_-hex_32>
CUBEJS_API_SECRET=<GENERATE_WITH_openssl_rand_-hex_32>

CUBEJS_JWT_ISSUER=formbricks-web
CUBEJS_JWT_AUDIENCE=formbricks-cube
CUBEJS_API_URL=http://cube:4000
HUB_API_URL=http://hub:8080

EMAIL_VERIFICATION_DISABLED=1
PASSWORD_RESET_DISABLED=1
