# {{ project_name }} — Hardened Container Runtime Base
# Rootless, privilege-dropped, resource-constrained infrastructure services
# for the shared development environment.
#
# SECURITY: No secrets are stored in this file or in .env files on disk.
# All application secrets are injected at container startup via
# `infisical run -- docker compose up -d`. The only credential on the
# droplet is the Infisical Machine Identity (see cloud-init).
#
# Required Infisical secrets:
#   DOCKER_SOCKET_PROXY_TOKEN   (shared secret for Docker API auth)
#   CADDY_METRICS_USER          (basic-auth user for /metrics endpoint)
#   CADDY_METRICS_PASS          (basic-auth password hash for /metrics)

services:
  # ─── Caddy reverse proxy ──────────────────────────────────────────────
  # Routes inbound HTTP/HTTPS traffic to per-developer containers.
  # TLS 1.3 only (enforced in Caddyfile). No privileged access to the host.
  caddy:
    image: {{ caddy_image | default('docker.io/library/caddy:2-alpine') }}
    restart: unless-stopped
    cap_drop:
      - ALL
    cap_add:
      - NET_BIND_SERVICE    # Required to bind privileged ports 80/443
      - NET_ADMIN           # Required for ACME HTTP-01 challenge routing
    read_only: true
    environment:
      DOMAIN: {{ domain }}
    ports:
      - "80:80"
      - "443:443"
      - "443:443/udp"
    volumes:
      - ./Caddyfile:/etc/caddy/Caddyfile:ro
      - caddy_data:/data
      - caddy_config:/config
    networks:
      - devboxnet
    healthcheck:
      test: ["CMD", "caddy", "version"]
      start_period: 10s
      interval: 30s
      timeout: 5s
      retries: 3
    deploy:
      resources:
        limits:
          cpus: "0.5"
          memory: 256M
        reservations:
          cpus: "0.1"
          memory: 64M
    logging:
      driver: json-file
      options:
        max-size: "10m"
        max-file: "3"
        tag: "{{ '{{' }}.Name{{ '}}' }}"

  # ─── Docker socket proxy ──────────────────────────────────────────────
  # Exposes a read-only, filtered Docker API endpoint so developer
  # containers can inspect / list containers without mounting the full
  # docker socket. The proxy enforces a shared-secret token and drops
  # all Linux capabilities — it needs none.
  #
  # Reference: https://github.com/Tecnativa/docker-socket-proxy
  docker-socket-proxy:
    image: docker.io/tecnativa/docker-socket-proxy:latest
    restart: unless-stopped
    cap_drop:
      - ALL
    read_only: true
    environment:
      # ── Security: deny by default, allow only what's needed ──
      CONTAINERS: "1"          # Allow listing / inspecting containers
      SERVICES: "1"            # Allow listing services
      TASKS: "1"               # Allow listing tasks
      NETWORKS: "1"            # Allow listing networks
      VERSIONS: "1"            # Allow version check
      POST: "0"                # Block all POST (no exec, no create)
      AUTH_CONFIG: "0"         # Disable registry auth passthrough
      BUILD: "0"               # Block build
      COMMIT: "0"              # Block commit
      CONFIGS: "0"             # Block config access
      DISTRIBUTION: "0"        # Block distribution
      EXEC: "0"                # Block exec
      GRPC: "0"                # Block gRPC
      IMAGES: "0"              # Block image operations
      INFO: "0"                # Block system info
      LOGS: "0"                # Block log access
      PLUGINS: "0"             # Block plugin management
      SECRETS: "0"             # Block secret access
      SESSION: "0"             # Block session
      SWARM: "0"               # Block swarm operations
      SYSTEM: "0"              # Block system DF
    volumes:
      - /var/run/docker.sock:/var/run/docker.sock:ro
    networks:
      - devboxnet
    healthcheck:
      test: ["CMD", "wget", "-q", "-O-", "http://localhost:2375/version"]
      start_period: 5s
      interval: 30s
      timeout: 5s
      retries: 3
    deploy:
      resources:
        limits:
          cpus: "0.2"
          memory: 64M
        reservations:
          cpus: "0.05"
          memory: 32M
    logging:
      driver: json-file
      options:
        max-size: "5m"
        max-file: "2"
        tag: "{{ '{{' }}.Name{{ '}}' }}"

volumes:
  caddy_data:
    name: {{ project_name | replace('-', '_') }}_caddy_data
  caddy_config:
    name: {{ project_name | replace('-', '_') }}_caddy_config

networks:
  devboxnet:
    name: {{ project_name | replace('-', '_') }}_net
    driver: bridge
    ipam:
      config:
        - subnet: 172.28.0.0/24
