#cloud-config
# {{ project_name }} - Cloud Init Configuration
# Managed by OpenTofu
#
# SECURITY: No application secrets (DB passwords, admin passwords, API keys)
# are written to disk. All application secrets are injected at container
# runtime via Infisical `infisical run`. The ONLY credential stored in
# cloud-init is the Infisical Machine Identity (Client ID + Secret), which
# is scoped to read-only access for this specific project.
#
# Infisical project secrets required:
#   DB_NAME, DB_USER, DB_PASSWORD, DB_ROOT_PASSWORD
#   KEYCLOAK_ADMIN_USERNAME, KEYCLOAK_ADMIN_PASSWORD
#   MINIMUS_TOKEN (if pulling from private registry)
#   SPACES_ACCESS_KEY, SPACES_SECRET_KEY (if backup_remote_storage = do-spaces)

package_update: true
packages:
  - apt-transport-https
  - ca-certificates
  - curl
  - gnupg
  - lsb-release
  - jq
  - unzip

write_files:
  # Docker installation script
  - path: /tmp/install-docker.sh
    permissions: "0755"
    content: |
      #!/bin/bash
      set -euo pipefail
      curl -fsSL https://get.docker.com -o /tmp/get-docker.sh
      sh /tmp/get-docker.sh
      systemctl enable docker
      systemctl start docker
      usermod -aG docker ubuntu

  # Infisical CLI installation
  - path: /tmp/install-infisical.sh
    permissions: "0755"
    content: |
      #!/bin/bash
      set -euo pipefail
      curl -fsSL https://infisical.com/install-cli.sh | bash

  # Docker daemon config for production
  - path: /etc/docker/daemon.json
    content: |
      {
        "log-driver": "json-file",
        "log-opts": {
          "max-size": "10m",
          "max-file": "3"
        },
        "storage-driver": "overlay2"
      }

  # Docker Compose file - NO secrets on disk
  # Variables are resolved at runtime by `infisical run` -> shell env -> docker compose
  - path: /opt/{{ project_name | replace('-', '') }}/compose.yaml
    permissions: "0644"
    content: |
      services:
        db:
          image: postgres:{{ postgres_version }}
          restart: unless-stopped
          environment:
            POSTGRES_DB: ${DB_NAME}
            POSTGRES_USER: ${DB_USER}
            POSTGRES_PASSWORD: ${DB_PASSWORD}
            POSTGRES_ROOT_PASSWORD: ${DB_ROOT_PASSWORD}
          volumes:
            - db_data:/var/lib/postgresql/data
          networks:
            - keycloaknet
          healthcheck:
            test: ["CMD-SHELL", "pg_isready -U ${DB_USER} -d ${DB_NAME}"]
            start_period: 30s
            interval: 10s
            timeout: 5s
            retries: 3
          deploy:
            resources:
              limits:
                memory: 512M
              reservations:
                memory: 256M

        keycloak:
          image: {{ keycloak_image }}
          restart: unless-stopped
          depends_on:
            db:
              condition: service_healthy
          environment:
            KC_DB: postgres
            KC_DB_URL: jdbc:postgresql://db:5432/${DB_NAME}
            KC_DB_USERNAME: ${DB_USER}
            KC_DB_PASSWORD: ${DB_PASSWORD}
            KC_HTTP_ENABLED: "true"
            KC_HTTP_PORT: 8080
            KC_HTTPS_CERTIFICATE_FILE: /etc/keycloak/tls/tls.crt
            KC_HTTPS_CERTIFICATE_KEY_FILE: /etc/keycloak/tls/tls.key
            KC_HOSTNAME_STRICT: "false"
            KC_HOSTNAME_STRICT_HTTPS: "false"
            KC_PROXY: edge
            KC_HEALTH_ENABLED: "true"
            KEYCLOAK_ADMIN: ${KEYCLOAK_ADMIN_USERNAME}
            KEYCLOAK_ADMIN_PASSWORD: ${KEYCLOAK_ADMIN_PASSWORD}
          volumes:
            - keycloak_data:/opt/keycloak/data
            - ./tls:/etc/keycloak/tls:ro
          networks:
            - keycloaknet
          healthcheck:
            test: ["CMD-SHELL", "exec 3<>/dev/tcp/127.0.0.1/8080; echo -e 'GET /health/ready HTTP/1.1\\r\\nhost: localhost\\r\\n\\r\\n' >&3; if [ $$? -eq 0 ]; then echo 'SUCCESS'; fi; exec 3<&-; exec 3>&-"]
            start_period: 60s
            interval: 30s
            timeout: 10s
            retries: 5
          deploy:
            resources:
              limits:
                memory: 2G
              reservations:
                memory: 1G

        caddy:
          image: {{ caddy_image }}
          restart: unless-stopped
          depends_on:
            - keycloak
          environment:
            DOMAIN: {{ domain }}
          ports:
            - "80:80"
            - "443:443"
            - "443:443/udp"
          volumes:
            - ./Caddyfile:/etc/caddy/Caddyfile:ro
            - caddy_data:/data
            - caddy_config:/config
          networks:
            - keycloaknet
          deploy:
            resources:
              limits:
                memory: 256M
              reservations:
                memory: 128M

      volumes:
        db_data:
          name: {{ project_name | replace('-', '_') }}_db_data
        keycloak_data:
          name: {{ project_name | replace('-', '_') }}_keycloak_data
        caddy_data:
          name: {{ project_name | replace('-', '_') }}_caddy_data
        caddy_config:
          name: {{ project_name | replace('-', '_') }}_caddy_config

      networks:
        keycloaknet:
          name: {{ project_name | replace('-', '_') }}_net
          driver: bridge

  # Caddyfile
  - path: /opt/{{ project_name | replace('-', '') }}/Caddyfile
    permissions: "0644"
    content: |
      {{ domain }} {
          reverse_proxy keycloak:8080 {
              flush_interval -1
          }
          log {
              output file /var/log/caddy/{{ project_name }}.log
          }
          tls {
              # Caddy automatically handles ACME for TLS
          }
      }

      admin.{{ domain }} {
          reverse_proxy keycloak:8080 {
              flush_interval -1
          }
      }

  # Skinny backup script - executed under `infisical run` so secrets are in env
  - path: /opt/{{ project_name | replace('-', '') }}/backup.sh
    permissions: "0750"
    content: |
      #!/usr/bin/env bash
      # {{ project_name }} - Skinny Backup Script
      # Assumes: called via `infisical run --projectId=... --env=... -- ./backup.sh`
      # so DB_PASSWORD, DB_USER, DB_NAME, SPACES_ACCESS_KEY, etc. are in environment.
      set -euo pipefail

      APP_DIR="/opt/{{ project_name | replace('-', '') }}"
      BACKUP_DIR="$APP_DIR/backups"
      TIMESTAMP=$(date +%Y%m%d_%H%M%S)
      BACKUP_NAME="{{ project_name }}_backup_$TIMESTAMP"
      WORK_DIR="$BACKUP_DIR/$BACKUP_NAME"
      PROJECT_NAME="{{ project_name | replace('-', '') }}"

      REMOTE_STORAGE="{{ backup_remote_storage }}"
      SPACES_BUCKET="{{ backup_do_spaces_bucket }}"
      SPACES_REGION="{{ backup_do_spaces_region }}"

      mkdir -p "$WORK_DIR"
      echo "==> Creating backup: $BACKUP_NAME"

      # --- Database dump (credentials from Infisical env) ---
      echo "==> Dumping PostgreSQL database..."
      docker exec -e PGPASSWORD="$DB_PASSWORD" "${PROJECT_NAME}-db-1" \
        pg_dump -U "$DB_USER" -d "$DB_NAME" > "$WORK_DIR/db.sql"

      DB_SIZE=$(wc -c < "$WORK_DIR/db.sql")
      echo "    Database dump: $DB_SIZE bytes"

      # --- Volume backups using ephemeral alpine containers ---
      echo "==> Backing up Keycloak data volume..."
      docker run --rm \
        -v "${PROJECT_NAME}_keycloak_data:/data:ro" \
        -v "$WORK_DIR:/backup" \
        alpine:3.19 \
        tar czf /backup/keycloak_data.tar.gz -C /data .

      echo "==> Backing up Caddy data volume..."
      docker run --rm \
        -v "${PROJECT_NAME}_caddy_data:/data:ro" \
        -v "$WORK_DIR:/backup" \
        alpine:3.19 \
        tar czf /backup/caddy_data.tar.gz -C /data .

      # --- Config snapshots ---
      cp "$APP_DIR/Caddyfile" "$WORK_DIR/"
      cp "$APP_DIR/compose.yaml" "$WORK_DIR/"
      docker ps --format 'table {{ "{{" }}.Names{{ "}}" }}\t{{ "{{" }}.Image{{ "}}" }}\t{{ "{{" }}.Status{{ "}}" }}' > "$WORK_DIR/containers.txt"

      # --- Compress ---
      cd "$BACKUP_DIR"
      tar czf "${BACKUP_NAME}.tar.gz" "$BACKUP_NAME"
      rm -rf "$WORK_DIR"

      BACKUP_SIZE=$(ls -lh "$BACKUP_DIR/${BACKUP_NAME}.tar.gz" | awk '{print $5}')
      echo "==> Local backup complete: $BACKUP_DIR/${BACKUP_NAME}.tar.gz ($BACKUP_SIZE)"

      # --- Remote upload (DO Spaces) ---
      if [[ "$REMOTE_STORAGE" == "do-spaces" ]]; then
        echo "==> Uploading to DO Spaces..."
        AWS_ACCESS_KEY_ID="$SPACES_ACCESS_KEY" \
        AWS_SECRET_ACCESS_KEY="$SPACES_SECRET_KEY" \
        aws s3 cp "$BACKUP_DIR/${BACKUP_NAME}.tar.gz" \
          "s3://${SPACES_BUCKET}/{{ project_name }}/" \
          --endpoint-url "https://${SPACES_REGION}.digitaloceanspaces.com" \
          --quiet
        echo "==> Uploaded to s3://${SPACES_BUCKET}/{{ project_name }}/"
      fi

      # --- Grandfather-Father-Son retention ---
      echo "==> Applying retention policy (daily 30d / monthly 12mo / yearly forever)..."
      find "$BACKUP_DIR" -maxdepth 1 -name "*.tar.gz" | while read -r f; do
        BASENAME=$(basename "$f")
        if [[ "$BASENAME" =~ _backup_([0-9]{8})_([0-9]{6})\.tar\.gz$ ]]; then
          FILE_DATE="${BASH_REMATCH[1]}"
          YEAR="${FILE_DATE:0:4}"
          MONTH="${FILE_DATE:4:2}"
          DAY="${FILE_DATE:6:2}"

          FILE_EPOCH=$(date -d "$YEAR-$MONTH-$DAY" +%s 2>/dev/null || echo 0)
          NOW_EPOCH=$(date +%s)
          AGE_DAYS=$(( (NOW_EPOCH - FILE_EPOCH) / 86400 ))

          KEEP=false
          if [[ $AGE_DAYS -lt 30 ]]; then
            KEEP=true
          elif [[ $AGE_DAYS -lt 365 && "$DAY" == "01" ]]; then
            KEEP=true
          elif [[ "$DAY" == "01" && "$MONTH" == "01" ]]; then
            KEEP=true
          fi

          if [[ "$KEEP" == "false" ]]; then
            echo "    Removing $BASENAME (${AGE_DAYS}d old)"
            rm -f "$f"
          fi
        fi
      done
      echo "==> Retention cleanup complete"

  # Infisical auth helper (run once at boot)
  - path: /opt/{{ project_name | replace('-', '') }}/infisical-auth.sh
    permissions: "0700"
    content: |
      #!/bin/bash
      set -euo pipefail
      export INFISICAL_CLIENT_ID='{{ infisical_client_id }}'
      export INFISICAL_CLIENT_SECRET='{{ infisical_client_secret }}'
      # Machine-identity headless auth: capture the token into INFISICAL_TOKEN so a
      # subsequent `infisical run` in the SAME shell reads it (a bare `infisical run`
      # after `login` finds no reusable session on a no-TTY box and hangs on a prompt).
      # Source this script in the shell that calls `infisical run` (boot + cron below).
      export INFISICAL_TOKEN="$(infisical login --method=universal-auth \
        --client-id="$INFISICAL_CLIENT_ID" \
        --client-secret="$INFISICAL_CLIENT_SECRET" \
        --plain --silent)"

  # Cron wrapper: logs in with Machine Identity, then runs backup with secrets injected
  - path: /etc/cron.daily/{{ project_name | replace('-', '') }}-backup
    permissions: "0750"
    content: |
      #!/bin/bash
      # Daily backup with Infisical runtime secret injection
      set -euo pipefail
      export INFISICAL_CLIENT_ID='{{ infisical_client_id }}'
      export INFISICAL_CLIENT_SECRET='{{ infisical_client_secret }}'
      export INFISICAL_TOKEN="$(infisical login --method=universal-auth \
        --client-id="$INFISICAL_CLIENT_ID" \
        --client-secret="$INFISICAL_CLIENT_SECRET" \
        --plain --silent)"
      infisical run \
        --projectId={{ infisical_project_id }} \
        --env={{ infisical_environment }} \
        -- /opt/{{ project_name | replace('-', '') }}/backup.sh \
        >> /var/log/{{ project_name | replace('-', '') }}-backup.log 2>&1

runcmd:
  # Install Docker
  - [bash, /tmp/install-docker.sh]

  # Install Infisical CLI
  - [bash, /tmp/install-infisical.sh]

  # AWS CLI v2 (DO Spaces is S3-compatible) via the official installer; apt awscli
  # is unreliable on current Ubuntu. Installs to /usr/local/bin. Best-effort.
  - 'bash -c "curl -fsSL https://awscli.amazonaws.com/awscli-exe-linux-x86_64.zip -o /tmp/awscliv2.zip && unzip -q -o /tmp/awscliv2.zip -d /tmp && /tmp/aws/install --update && rm -rf /tmp/aws /tmp/awscliv2.zip || echo awscli-v2-install-failed"'

  # Create application directories
  - [mkdir, -p, /opt/{{ project_name | replace('-', '') }}]
  - [mkdir, -p, /opt/{{ project_name | replace('-', '') }}/backups]
  - [mkdir, -p, /opt/{{ project_name | replace('-', '') }}/tls]
  # Caddy log dir: the hardened (non-root) caddy image writes its access log to
  # the /var/log/caddy host bind mount and crash-loops with "permission denied"
  # if the dir does not exist writable. 0777 is fine for a single-tenant log dir
  # (otel-agent also reads these files).
  - [mkdir, -p, /var/log/caddy]
  - [chmod, "0777", /var/log/caddy]

  # Pull container images
  - [docker, pull, {{ keycloak_image }}]
  - [docker, pull, {{ caddy_image }}]
  - [docker, pull, postgres:{{ postgres_version }}]

  # Apply Docker daemon configuration
  - [systemctl, restart, docker]

  # Start the stack - secrets injected at runtime by Infisical.
  # Source infisical-auth.sh in THIS shell so INFISICAL_TOKEN is set for `infisical run`.
  - |
    # shellcheck disable=SC1091
    source /opt/{{ project_name | replace('-', '') }}/infisical-auth.sh
    cd /opt/{{ project_name | replace('-', '') }} && \
    infisical run \
      --projectId={{ infisical_project_id }} \
      --env={{ infisical_environment }} \
      -- docker compose up -d

  # Enable automatic security updates
  - dpkg-reconfigure -plow unattended-upgrades

final_message: "{{ project_name }} setup complete - Infisical runtime injection active, skinny backups enabled"
