# {{ project_name }} - Keycloak Role
# Keycloak-specific configuration

- name: Create Keycloak data directory
  ansible.builtin.file:
    path: "{{ app_dir }}/data"
    state: directory
    mode: '0755'
    owner: ubuntu
    group: ubuntu

- name: Create TLS directory
  ansible.builtin.file:
    path: "{{ app_dir }}/tls"
    state: directory
    mode: '0755'
    owner: ubuntu
    group: ubuntu

- name: Check if Keycloak container exists
  community.docker.docker_container_info:
    name: "{{ project_name }}-keycloak-1"
  register: keycloak_container

- name: Pull Keycloak image
  community.docker.docker_image:
    name: "{{ keycloak_image }}"
    source: pull
  when: keycloak_container is not defined or keycloak_container.container is none

- name: Ensure compose file is present
  ansible.builtin.copy:
    dest: "{{ app_dir }}/compose.yaml"
    content: |
      # This file is managed by the deploy script - manual changes will be overwritten
      # See scripts/deploy.sh for the authoritative compose configuration
    mode: '0644'
  when: false  # Managed by deploy script

- name: Check Keycloak health
  when: keycloak_container.container is defined and keycloak_container.container != none
  block:
    - name: Get Keycloak container status
      community.docker.docker_container_info:
        name: "{{ project_name }}-keycloak-1"
      register: keycloak_status

    - name: Restart Keycloak if unhealthy
      when: keycloak_status.container is defined and keycloak_status.container.State.Health.Status != "healthy"
      ansible.builtin.shell: |
        cd {{ app_dir }} && docker compose restart keycloak
      changed_when: true
