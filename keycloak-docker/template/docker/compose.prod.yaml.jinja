# {{ project_name }} - Docker Compose (ADR-006: In-Container Infisical Injection)
# Secrets are fetched IN-PROCESS by containers at startup via `infisical run` entrypoint.
# A `docker restart` re-fetches secrets (bounce-to-refresh). No secrets in environment: blocks.
# No secrets should be stored in this file or in .env files on disk.
#
# Required Infisical secrets (names must match each app's expected env var names):
#   PostgreSQL: POSTGRES_DB, POSTGRES_USER, POSTGRES_PASSWORD, POSTGRES_ROOT_PASSWORD
#   Keycloak:   KC_DB_USERNAME, KC_DB_PASSWORD, KEYCLOAK_ADMIN, KEYCLOAK_ADMIN_PASSWORD
#
# Copier variables used in environment blocks:
#   KC_DB_URL_DATABASE: database name for Keycloak JDBC URL (copier var: keycloak_db_name)
#
# Note: KC_DB_USERNAME and KC_DB_PASSWORD hold the same values as POSTGRES_USER and
# POSTGRES_PASSWORD respectively, but are stored as separate Infisical secrets so each
# app sees the env var names it expects. This is the ADR-006 approach: no ${VAR}
# interpolation in compose, secrets fetched in-process by infisical run entrypoint.

services:
  db:
    image: postgres:{{ postgres_version }}
    restart: unless-stopped
    # ADR-006: wrapper script authenticates to Infisical and execs original entrypoint
    entrypoint: ["/opt/{{ project_name | replace('-', '_') }}/entrypoint-infisical.sh"]
    command: ["postgres"]
    volumes:
      - db_data:/var/lib/postgresql/data
      # ADR-006: bind-mount Infisical CLI + auth file + wrapper script (read-only)
      - /usr/bin/infisical:/usr/bin/infisical:ro
      - /opt/{{ project_name | replace('-', '_') }}/.infisical-auth.env.container:/.infisical-auth.env:ro
      - /opt/{{ project_name | replace('-', '_') }}/entrypoint-infisical.sh:/opt/{{ project_name | replace('-', '_') }}/entrypoint-infisical.sh:ro
    networks:
      - keycloaknet
    healthcheck:
      # POSTGRES_USER is injected at runtime by infisical run, not available at
      # compose parse time. Use a simple TCP check instead of pg_isready -U.
      test: ["CMD-SHELL", "pg_isready -h localhost"]
      start_period: 30s
      interval: 10s
      timeout: 5s
      retries: 3
    deploy:
      resources:
        limits:
          memory: 512M
        reservations:
          memory: 256M

  keycloak:
    image: {{ keycloak_image }}
    restart: unless-stopped
    depends_on:
      db:
        condition: service_healthy
    # ADR-006: wrapper script authenticates to Infisical and execs original entrypoint
    entrypoint: ["/opt/{{ project_name | replace('-', '_') }}/entrypoint-infisical.sh"]
    command: ["/opt/keycloak/bin/kc.sh", "start"]
    environment:
      # Non-secret config only; secrets fetched by entrypoint
      KC_DB: postgres
      KC_DB_URL_HOST: db
      KC_DB_URL_PORT: "5432"
      KC_DB_URL_DATABASE: "{{ keycloak_db_name }}"
      KC_HTTP_ENABLED: "true"
      KC_HTTP_PORT: 8080
      KC_HTTPS_CERTIFICATE_FILE: /etc/keycloak/tls/tls.crt
      KC_HTTPS_CERTIFICATE_KEY_FILE: /etc/keycloak/tls/tls.key
      KC_HOSTNAME_STRICT: "false"
      KC_HOSTNAME_STRICT_HTTPS: "false"
      KC_PROXY: edge
      KC_HEALTH_ENABLED: "true"
      # Secrets (KC_DB_USERNAME, KC_DB_PASSWORD, KEYCLOAK_ADMIN, KEYCLOAK_ADMIN_PASSWORD)
      # fetched by entrypoint, NOT listed here.
    volumes:
      - keycloak_data:/opt/keycloak/data
      - ./tls:/etc/keycloak/tls:ro
      # ADR-006: bind-mount Infisical CLI + auth file + wrapper script (read-only)
      - /usr/bin/infisical:/usr/bin/infisical:ro
      - /opt/{{ project_name | replace('-', '_') }}/.infisical-auth.env.container:/.infisical-auth.env:ro
      - /opt/{{ project_name | replace('-', '_') }}/entrypoint-infisical.sh:/opt/{{ project_name | replace('-', '_') }}/entrypoint-infisical.sh:ro
    networks:
      - keycloaknet
    healthcheck:
      test: ["CMD-SHELL", "exec 3<>/dev/tcp/127.0.0.1/8080; echo -e 'GET /health/ready HTTP/1.1\\r\\nhost: localhost\\r\\n\\r\\n' >&3; if [ $$? -eq 0 ]; then echo 'SUCCESS'; fi; exec 3<&-; exec 3>&-"]
      start_period: 60s
      interval: 30s
      timeout: 10s
      retries: 5
    deploy:
      resources:
        limits:
          memory: 2G
        reservations:
          memory: 1G

  caddy:
    image: {{ caddy_image }}
    restart: unless-stopped
    depends_on:
      - keycloak
    environment:
      DOMAIN: {{ domain }}
    ports:
      - "80:80"
      - "443:443"
      - "443:443/udp"
    volumes:
      - ./Caddyfile:/etc/caddy/Caddyfile:ro
      - caddy_data:/data
      - caddy_config:/config
    networks:
      - keycloaknet
    deploy:
      resources:
        limits:
          memory: 256M
        reservations:
          memory: 128M

volumes:
  db_data:
    name: {{ project_name | replace('-', '_') }}_db_data
  keycloak_data:
    name: {{ project_name | replace('-', '_') }}_keycloak_data
  caddy_data:
    name: {{ project_name | replace('-', '_') }}_caddy_data
  caddy_config:
    name: {{ project_name | replace('-', '_') }}_caddy_config

networks:
  keycloaknet:
    name: {{ project_name | replace('-', '_') }}_net
    driver: bridge
