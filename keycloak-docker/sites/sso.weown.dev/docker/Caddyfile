# sso.weown.dev - Caddyfile
# Reverse proxy for Keycloak SSO

sso.weown.dev {
    reverse_proxy keycloak:8080 {
        flush_interval -1
        # Forwarded header (RFC 7239) required by Keycloak KC_PROXY_HEADERS=forwarded
        # Without this, Keycloak generates HTTP URLs in OIDC metadata (issuer, auth endpoint)
        header_up Forwarded "proto=https;host={host}"
    }

    log {
        output file /var/log/caddy/sso.log
    }
}

# Keycloak admin console (restrict access in production)
admin.sso.weown.dev {
    reverse_proxy keycloak:8080 {
        flush_interval -1
        header_up Forwarded "proto=https;host={host}"
    }
}
