# {{ project_name }} - oCIS Role
# ownCloud Infinite Scale configuration

- name: Create oCIS data directory
  ansible.builtin.file:
    path: "{{ app_dir }}/data"
    state: directory
    mode: '0755'
    owner: ubuntu
    group: ubuntu

- name: Check if oCIS container exists
  community.docker.docker_container_info:
    name: "{{ project_name }}-ocis-1"
  register: ocis_container

- name: Pull oCIS image
  community.docker.docker_image:
    name: "{{ ocis_image }}"
    source: pull
  when: ocis_container is not defined or ocis_container.container is none

- name: Ensure compose file is present
  ansible.builtin.copy:
    dest: "{{ app_dir }}/compose.yaml"
    content: |
      # This file is managed by the deploy script - manual changes will be overwritten
      # See scripts/deploy.sh for the authoritative compose configuration
    mode: '0644'
  when: false  # Managed by deploy script

- name: Check oCIS health
  when: ocis_container.container is defined and ocis_container.container != none
  block:
    - name: Get oCIS container status
      community.docker.docker_container_info:
        name: "{{ project_name }}-ocis-1"
      register: ocis_status

    - name: Restart oCIS if unhealthy
      when: ocis_status.container is defined and ocis_status.container.State.Health.Status != "healthy"
      ansible.builtin.shell: |
        cd {{ app_dir }} && docker compose restart ocis
      changed_when: true
