# {{ project_name }} - Production Environment Variables
# ⚠️ CRITICAL: Never commit .env.prod with real values
# Use Infisical to manage production secrets

# Domain
DOMAIN={{ domain }}

# Container Images
OCIS_IMAGE=owncloud/ocis:7.1.1
CADDY_IMAGE=reg.mini.dev/caddy:2

# oCIS Secrets (get from Infisical)
OCIS_JWT_SECRET=<GET_FROM_INFISICAL>
IDM_ADMIN_PASSWORD=<GET_FROM_INFISICAL>
IDP_LDAP_BIND_PASSWORD=<GET_FROM_INFISICAL>
STORAGE_TRANSFER_SECRET=<GET_FROM_INFISICAL>
THUMBNAILS_TRANSFER_SECRET=<GET_FROM_INFISICAL>
MACHINE_AUTH_API_KEY=<GET_FROM_INFISICAL>
OCIS_SYSTEM_USER_API_KEY=<GET_FROM_INFISICAL>

# Infisical
ENABLE_INFISICAL=true
INFISICAL_TOKEN=<GET_FROM_INFISICAL>
INFISICAL_PROJECT_ID=<GET_FROM_INFISICAL>
INFISICAL_ENVIRONMENT=prod
