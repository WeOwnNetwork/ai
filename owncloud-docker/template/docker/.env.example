# {{ project_name }} - Environment Variables Example
# ⚠️ DEPRECATED: This project uses Infisical runtime injection.
# Do NOT create .env files with real secrets.
#
# Secrets are fetched from Infisical at container startup:
#   infisical run --env=prod -- docker compose up -d
#
# Required Infisical secrets (add these in your Infisical project):
#   OCIS_JWT_SECRET, IDM_ADMIN_PASSWORD, IDP_LDAP_BIND_PASSWORD
#   STORAGE_TRANSFER_SECRET, THUMBNAILS_TRANSFER_SECRET
#   MACHINE_AUTH_API_KEY, OCIS_SYSTEM_USER_API_KEY
#   SPACES_ACCESS_KEY, SPACES_SECRET_KEY (for backups)
#
# Only the Infisical Machine Identity (Client ID + Client Secret)
# should exist on the host — everything else comes from Infisical.

# Domain (non-sensitive — can stay here or move to Infisical)
DOMAIN={{ domain }}

# Container Images (non-sensitive)
OCIS_IMAGE={{ ocis_image }}
CADDY_IMAGE={{ caddy_image }}

# Infisical Configuration (Machine Identity only)
INFISICAL_CLIENT_ID=your-client-id
INFISICAL_CLIENT_SECRET=your-client-secret
INFISICAL_PROJECT_ID={{ infisical_project_id | default('') }}
INFISICAL_ENVIRONMENT={{ infisical_environment | default('prod') }}
