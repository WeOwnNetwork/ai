# {{ project_name }} - Terraform Outputs
# Managed by OpenTofu

output "droplet_ip" {
  description = "Droplet IPv4 address (reserved IP)"
  value       = digitalocean_reserved_ip.ocis.ip_address
}

output "droplet_id" {
  description = "Droplet ID"
  value       = digitalocean_droplet.ocis.id
}

output "domain" {
  description = "Primary domain"
  value       = var.domain
}

output "owncloud_url" {
  description = "ownCloud application URL"
  value       = "https://${var.domain}"
}

output "infisical_project" {
  description = "Infisical project ID for secrets management"
  value       = var.infisical_project_id
}
