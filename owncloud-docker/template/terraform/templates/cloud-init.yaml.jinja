#cloud-config
# {{ project_name }} - Cloud Init Configuration
# Managed by OpenTofu
#
# SECURITY: No application secrets (OCIS_JWT_SECRET, IDM_ADMIN_PASSWORD, etc.)
# are written to disk. All application secrets are injected at container
# runtime via Infisical `infisical run`. The ONLY credential stored in
# cloud-init is the Infisical Machine Identity (Client ID + Secret), which
# is scoped to read-only access for this specific project.
#
# Infisical project secrets required:
#   OCIS_JWT_SECRET              → JWT signing secret for oCIS auth
#   IDM_ADMIN_PASSWORD           → Initial admin password for ownCloud
#   IDP_LDAP_BIND_PASSWORD       → LDAP bind password for built-in IDP
#   STORAGE_TRANSFER_SECRET      → Storage transfer secret between services
#   THUMBNAILS_TRANSFER_SECRET   → Thumbnails service transfer secret
#   MACHINE_AUTH_API_KEY         → Machine-to-machine auth API key
#   OCIS_SYSTEM_USER_API_KEY     → System user API key for internal operations
#   SPACES_ACCESS_KEY            → (optional) DO Spaces key for remote backups
#   SPACES_SECRET_KEY            → (optional) DO Spaces secret for remote backups

package_update: true
packages:
  - apt-transport-https
  - ca-certificates
  - curl
  - gnupg
  - lsb-release
  - jq
  - awscli

write_files:
  # Docker installation script
  - path: /tmp/install-docker.sh
    permissions: "0755"
    content: |
      #!/bin/bash
      set -euo pipefail
      curl -fsSL https://get.docker.com -o /tmp/get-docker.sh
      sh /tmp/get-docker.sh
      systemctl enable docker
      systemctl start docker
      usermod -aG docker ubuntu

  # Infisical CLI installation
  - path: /tmp/install-infisical.sh
    permissions: "0755"
    content: |
      #!/bin/bash
      set -euo pipefail
      curl -fsSL https://infisical.com/install-cli.sh | bash

  # Docker daemon config for production
  - path: /etc/docker/daemon.json
    content: |
      {
        "log-driver": "json-file",
        "log-opts": {
          "max-size": "10m",
          "max-file": "3"
        },
        "storage-driver": "overlay2"
      }

  # Docker Compose file — NO secrets on disk
  # Variables are resolved at runtime by `infisical run` → shell env → docker compose
  - path: /opt/{{ project_name | replace('-', '') }}/compose.yaml
    permissions: "0644"
    content: |
      services:
        ocis:
          image: {{ ocis_image }}
          restart: unless-stopped
          entrypoint:
            - /bin/sh
          command: ["-c", "ocis init || true; ocis server"]
          environment:
            # Domain and URL configuration
            OCIS_URL: "https://{{ domain }}"
            PROXY_HTTP_ADDR: "0.0.0.0:9200"
            OCIS_INSECURE: "false"
            # Logging
            OCIS_LOG_LEVEL: "warn"
            OCIS_LOG_COLOR: "false"
            OCIS_LOG_PRETTY: "false"
            # Secrets (injected from Infisical)
            OCIS_JWT_SECRET: "$${OCIS_JWT_SECRET}"
            IDM_ADMIN_PASSWORD: "$${IDM_ADMIN_PASSWORD}"
            IDP_LDAP_BIND_PASSWORD: "$${IDP_LDAP_BIND_PASSWORD}"
            STORAGE_TRANSFER_SECRET: "$${STORAGE_TRANSFER_SECRET}"
            THUMBNAILS_TRANSFER_SECRET: "$${THUMBNAILS_TRANSFER_SECRET}"
            MACHINE_AUTH_API_KEY: "$${MACHINE_AUTH_API_KEY}"
            OCIS_SYSTEM_USER_API_KEY: "$${OCIS_SYSTEM_USER_API_KEY}"
            # Proxy trust configuration (Caddy terminates TLS)
            PROXY_TLS: "false"
            PROXY_CSP_CONFIG_FILE_LOCATION: ""
          volumes:
            - ocis_config:/etc/ocis
            - ocis_data:/var/lib/ocis
          networks:
            - owncloudnet
          healthcheck:
            test: ["CMD", "curl", "-f", "http://localhost:9200/healthz"]
            start_period: 60s
            interval: 30s
            timeout: 10s
            retries: 5
          deploy:
            resources:
              limits:
                memory: 2G
              reservations:
                memory: 512M

        caddy:
          image: {{ caddy_image }}
          restart: unless-stopped
          depends_on:
            ocis:
              condition: service_healthy
          environment:
            DOMAIN: {{ domain }}
          ports:
            - "80:80"
            - "443:443"
            - "443:443/udp"
          volumes:
            - ./Caddyfile:/etc/caddy/Caddyfile:ro
            - caddy_data:/data
            - caddy_config:/config
          networks:
            - owncloudnet
          deploy:
            resources:
              limits:
                memory: 256M
              reservations:
                memory: 128M

      volumes:
        ocis_config:
          name: {{ project_name | replace('-', '_') }}_config
        ocis_data:
          name: {{ project_name | replace('-', '_') }}_data
        caddy_data:
          name: {{ project_name | replace('-', '_') }}_caddy_data
        caddy_config:
          name: {{ project_name | replace('-', '_') }}_caddy_config

      networks:
        owncloudnet:
          name: {{ project_name | replace('-', '_') }}_net
          driver: bridge

  # Caddyfile
  - path: /opt/{{ project_name | replace('-', '') }}/Caddyfile
    permissions: "0644"
    content: |
      {{ domain }} {
          reverse_proxy ocis:9200 {
              flush_interval -1
          }
          log {
              output file /var/log/caddy/{{ project_name }}.log
          }
          tls {
              # Caddy automatically handles ACME for TLS
          }
      }

  # Skinny backup script — executed under `infisical run` so secrets are in env
  - path: /opt/{{ project_name | replace('-', '') }}/backup.sh
    permissions: "0750"
    content: |
      #!/usr/bin/env bash
      # {{ project_name }} - Skinny Backup Script
      # Assumes: called via `infisical run --projectId=... --env=... -- ./backup.sh`
      # so SPACES_ACCESS_KEY, SPACES_SECRET_KEY are in environment.
      set -euo pipefail

      APP_DIR="/opt/{{ project_name | replace('-', '') }}"
      BACKUP_DIR="$APP_DIR/backups"
      TIMESTAMP=$(date +%Y%m%d_%H%M%S)
      BACKUP_NAME="{{ project_name }}_backup_$TIMESTAMP"
      WORK_DIR="$BACKUP_DIR/$BACKUP_NAME"
      PROJECT_NAME="{{ project_name | replace('-', '') }}"

      REMOTE_STORAGE="{{ backup_remote_storage }}"
      SPACES_BUCKET="{{ backup_do_spaces_bucket }}"
      SPACES_REGION="{{ backup_do_spaces_region }}"

      mkdir -p "$WORK_DIR"
      echo "==> Creating backup: $BACKUP_NAME"

      # --- Volume backups using ephemeral alpine containers ---
      echo "==> Backing up oCIS config volume..."
      docker run --rm \
        -v "$${PROJECT_NAME}_config:/data:ro" \
        -v "$WORK_DIR:/backup" \
        alpine:3.19 \
        tar czf /backup/ocis_config.tar.gz -C /data .

      echo "==> Backing up oCIS data volume..."
      docker run --rm \
        -v "$${PROJECT_NAME}_data:/data:ro" \
        -v "$WORK_DIR:/backup" \
        alpine:3.19 \
        tar czf /backup/ocis_data.tar.gz -C /data .

      echo "==> Backing up Caddy data volume..."
      docker run --rm \
        -v "$${PROJECT_NAME}_caddy_data:/data:ro" \
        -v "$WORK_DIR:/backup" \
        alpine:3.19 \
        tar czf /backup/caddy_data.tar.gz -C /data .

      # --- Config snapshots ---
      cp "$APP_DIR/Caddyfile" "$WORK_DIR/"
      cp "$APP_DIR/compose.yaml" "$WORK_DIR/"
      docker ps --format 'table {{ "{{" }}.Names{{ "}}" }}\t{{ "{{" }}.Image{{ "}}" }}\t{{ "{{" }}.Status{{ "}}" }}' > "$WORK_DIR/containers.txt"
      docker images --format '{{ "{{" }}.Repository{{ "}}" }}:{{ "{{" }}.Tag{{ "}}" }}\t{{ "{{" }}.ID{{ "}}" }}\t{{ "{{" }}.Size{{ "}}" }}' > "$WORK_DIR/images.txt"

      # --- Compress ---
      cd "$BACKUP_DIR"
      tar czf "$${BACKUP_NAME}.tar.gz" "$BACKUP_NAME"
      rm -rf "$WORK_DIR"

      BACKUP_SIZE=$(ls -lh "$BACKUP_DIR/$${BACKUP_NAME}.tar.gz" | awk '{print $5}')
      echo "==> Local backup complete: $BACKUP_DIR/$${BACKUP_NAME}.tar.gz ($BACKUP_SIZE)"

      # --- Remote upload (DO Spaces) ---
      if [[ "$REMOTE_STORAGE" == "do-spaces" ]]; then
        echo "==> Uploading to DO Spaces..."
        AWS_ACCESS_KEY_ID="$SPACES_ACCESS_KEY" \
        AWS_SECRET_ACCESS_KEY="$SPACES_SECRET_KEY" \
        aws s3 cp "$BACKUP_DIR/$${BACKUP_NAME}.tar.gz" \
          "s3://$${SPACES_BUCKET}/{{ project_name }}/" \
          --endpoint-url "https://$${SPACES_REGION}.digitaloceanspaces.com" \
          --quiet
        echo "==> Uploaded to s3://$${SPACES_BUCKET}/{{ project_name }}/"
      fi

      # --- Grandfather-Father-Son retention ---
      echo "==> Applying retention policy (daily 30d / monthly 12mo / yearly forever)..."
      find "$BACKUP_DIR" -maxdepth 1 -name "*.tar.gz" | while read -r f; do
        BASENAME=$(basename "$f")
        if [[ "$BASENAME" =~ _backup_([0-9]{8})_([0-9]{6})\.tar\.gz$ ]]; then
          FILE_DATE="$${BASH_REMATCH[1]}"
          YEAR="$${FILE_DATE:0:4}"
          MONTH="$${FILE_DATE:4:2}"
          DAY="$${FILE_DATE:6:2}"

          FILE_EPOCH=$(date -d "$YEAR-$MONTH-$DAY" +%s 2>/dev/null || echo 0)
          NOW_EPOCH=$(date +%s)
          AGE_DAYS=$(( (NOW_EPOCH - FILE_EPOCH) / 86400 ))

          KEEP=false
          if [[ $AGE_DAYS -lt 30 ]]; then
            KEEP=true
          elif [[ $AGE_DAYS -lt 365 && "$DAY" == "01" ]]; then
            KEEP=true
          elif [[ "$DAY" == "01" && "$MONTH" == "01" ]]; then
            KEEP=true
          fi

          if [[ "$KEEP" == "false" ]]; then
            echo "    Removing $BASENAME ($${AGE_DAYS}d old)"
            rm -f "$f"
          fi
        fi
      done
      echo "==> Retention cleanup complete"

  # Infisical auth helper (run once at boot)
  - path: /opt/{{ project_name | replace('-', '') }}/infisical-auth.sh
    permissions: "0700"
    content: |
      #!/bin/bash
      set -euo pipefail
      export INFISICAL_CLIENT_ID='{{ infisical_client_id }}'
      export INFISICAL_CLIENT_SECRET='{{ infisical_client_secret }}'
      infisical login --method=universal-auth \
        --clientId="$INFISICAL_CLIENT_ID" \
        --clientSecret="$INFISICAL_CLIENT_SECRET" \
        --silent

  # Cron wrapper: logs in with Machine Identity, then runs backup with secrets injected
  - path: /etc/cron.daily/{{ project_name | replace('-', '') }}-backup
    permissions: "0750"
    content: |
      #!/bin/bash
      # Daily backup with Infisical runtime secret injection
      set -euo pipefail
      export INFISICAL_CLIENT_ID='{{ infisical_client_id }}'
      export INFISICAL_CLIENT_SECRET='{{ infisical_client_secret }}'
      infisical login --method=universal-auth \
        --clientId="$INFISICAL_CLIENT_ID" \
        --clientSecret="$INFISICAL_CLIENT_SECRET" \
        --silent
      infisical run \
        --projectId={{ infisical_project_id }} \
        --env={{ infisical_environment }} \
        -- /opt/{{ project_name | replace('-', '') }}/backup.sh \
        >> /var/log/{{ project_name | replace('-', '') }}-backup.log 2>&1

runcmds:
  # Install Docker
  - [bash, /tmp/install-docker.sh]

  # Install Infisical CLI
  - [bash, /tmp/install-infisical.sh]

  # Create application directories
  - [mkdir, -p, /opt/{{ project_name | replace('-', '') }}]
  - [mkdir, -p, /opt/{{ project_name | replace('-', '') }}/backups]

  # Authenticate Infisical (stores token for root user)
  - [bash, /opt/{{ project_name | replace('-', '') }}/infisical-auth.sh]

  # Pull container images
  - [docker, pull, {{ ocis_image }}]
  - [docker, pull, {{ caddy_image }}]

  # Apply Docker daemon configuration
  - [systemctl, restart, docker]

  # Start the stack — secrets injected at runtime by Infisical
  - |
    cd /opt/{{ project_name | replace('-', '') }} && \
    infisical run \
      --projectId={{ infisical_project_id }} \
      --env={{ infisical_environment }} \
      -- docker compose up -d

  # Enable automatic security updates
  - dpkg-reconfigure -plow unattended-upgrades

final_message: "{{ project_name }} setup complete — Infisical runtime injection active, skinny backups enabled"
