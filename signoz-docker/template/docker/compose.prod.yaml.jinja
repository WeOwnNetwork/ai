# {{ project_name }} - Docker Compose (ADR-006: In-Container Infisical Injection)
# SigNoz observability platform: ClickHouse + OTel Collector Gateway + SigNoz UI
# Secrets are fetched IN-PROCESS by containers at startup via `infisical run` entrypoint.
# A `docker restart` re-fetches secrets (bounce-to-refresh). No secrets in environment: blocks.
# No secrets should be stored in this file or in .env files on disk.
#
# Required Infisical secrets:
#   CLICKHOUSE_PASSWORD (shared by clickhouse, signoz, signoz-schema-migrator, otel-collector-gateway)
#   SIGNOZ_ADMIN_EMAIL, SIGNOZ_ADMIN_PASSWORD
# Optional Infisical secrets:
#   MINIMUS_TOKEN (for private registry pulls)

services:
  zookeeper:
    image: bitnami/zookeeper:{{ zookeeper_version }}
    restart: unless-stopped
    # ZooKeeper auth is intentionally disabled: this is the SigNoz fallback
    # template (primary path is SigNoz Cloud + otel-agent/, see CHANGELOG).
    # The port is NOT published to host (only reachable on `signoznet` by
    # ClickHouse). Enabling SASL would require synchronized ClickHouse
    # zookeeper.xml credentials and a new Infisical secret — out of scope.
    # If you adopt this template for production, enable ZOO_ENABLE_AUTH and
    # wire matching ClickHouse credentials before exposing the stack.
    environment:
      ALLOW_ANONYMOUS_LOGIN: "yes"
      ZOO_AUTOPURGE_INTERVAL: "1"
      ZOO_AUTOPURGE_RETAIN_COUNT: "3"
    volumes:
      - zookeeper_data:/bitnami/zookeeper
    networks:
      - signoznet
    healthcheck:
      test: ["CMD-SHELL", "echo ruok | nc localhost 2181 | grep -q imok"]
      start_period: 30s
      interval: 10s
      timeout: 5s
      retries: 3
    deploy:
      resources:
        limits:
          memory: 512M
        reservations:
          memory: 256M

  clickhouse:
    image: clickhouse/clickhouse-server:{{ clickhouse_version }}
    restart: unless-stopped
    depends_on:
      zookeeper:
        condition: service_healthy
    # ADR-006: wrapper script authenticates to Infisical and execs original entrypoint
    entrypoint: ["/opt/{{ project_name | replace('-', '_') }}/entrypoint-infisical.sh"]
    command: ["/entrypoint.sh"]
    environment:
      # Non-secret config only; CLICKHOUSE_PASSWORD fetched by entrypoint
      CLICKHOUSE_DB: signoz
      CLICKHOUSE_USER: default
    volumes:
      - clickhouse_data:/var/lib/clickhouse
      - clickhouse_logs:/var/log/clickhouse-server
      # ADR-006: bind-mount Infisical CLI + auth file + wrapper script (read-only)
      - /usr/bin/infisical:/usr/bin/infisical:ro
      - /opt/{{ project_name | replace('-', '_') }}/.infisical-auth.env.container:/.infisical-auth.env:ro
      - /opt/{{ project_name | replace('-', '_') }}/entrypoint-infisical.sh:/opt/{{ project_name | replace('-', '_') }}/entrypoint-infisical.sh:ro
    networks:
      - signoznet
    healthcheck:
      # CLICKHOUSE_PASSWORD is injected at runtime by infisical run, not available
      # at compose parse time. Use unauthenticated HTTP ping endpoint (port 8123).
      test: ["CMD-SHELL", "wget --spider -q 0.0.0.0:8123/ping"]
      start_period: 60s
      interval: 15s
      timeout: 10s
      retries: 5
    deploy:
      resources:
        limits:
          memory: 4G
        reservations:
          memory: 2G
    ulimits:
      nofile:
        soft: 262144
        hard: 262144

  signoz-schema-migrator:
    image: signoz/signoz-schema-migrator:{{ signoz_version }}
    restart: on-failure
    depends_on:
      clickhouse:
        condition: service_healthy
    # ADR-006: wrapper script authenticates to Infisical and execs original entrypoint
    entrypoint: ["/opt/{{ project_name | replace('-', '_') }}/entrypoint-infisical.sh"]
    command: ["/signoz-schema-migrator"]
    environment:
      # Non-secret config only; CLICKHOUSE_PASSWORD fetched by entrypoint
      STORAGE: clickhouse
      CLICKHOUSE_HOST: clickhouse
      CLICKHOUSE_PORT: "9000"
      CLICKHOUSE_USER: default
      CLICKHOUSE_DATABASE: signoz
    volumes:
      # ADR-006: bind-mount Infisical CLI + auth file + wrapper script (read-only)
      - /usr/bin/infisical:/usr/bin/infisical:ro
      - /opt/{{ project_name | replace('-', '_') }}/.infisical-auth.env.container:/.infisical-auth.env:ro
      - /opt/{{ project_name | replace('-', '_') }}/entrypoint-infisical.sh:/opt/{{ project_name | replace('-', '_') }}/entrypoint-infisical.sh:ro
    networks:
      - signoznet

  signoz:
    image: signoz/signoz:{{ signoz_version }}
    restart: unless-stopped
    depends_on:
      clickhouse:
        condition: service_healthy
      signoz-schema-migrator:
        condition: service_completed_successfully
    # ADR-006: wrapper script authenticates to Infisical and execs original entrypoint
    entrypoint: ["/opt/{{ project_name | replace('-', '_') }}/entrypoint-infisical.sh"]
    command: ["/signoz"]
    environment:
      # Non-secret config only; secrets fetched by entrypoint
      STORAGE: clickhouse
      CLICKHOUSE_HOST: clickhouse
      CLICKHOUSE_PORT: "9000"
      CLICKHOUSE_USER: default
      CLICKHOUSE_DATABASE: signoz
      GODEBUG: "netdns=go"
      # Secrets (CLICKHOUSE_PASSWORD, SIGNOZ_ADMIN_EMAIL, SIGNOZ_ADMIN_PASSWORD)
      # fetched by entrypoint, NOT listed here.
    volumes:
      - signoz_data:/var/lib/signoz
      # ADR-006: bind-mount Infisical CLI + auth file + wrapper script (read-only)
      - /usr/bin/infisical:/usr/bin/infisical:ro
      - /opt/{{ project_name | replace('-', '_') }}/.infisical-auth.env.container:/.infisical-auth.env:ro
      - /opt/{{ project_name | replace('-', '_') }}/entrypoint-infisical.sh:/opt/{{ project_name | replace('-', '_') }}/entrypoint-infisical.sh:ro
    networks:
      - signoznet
    healthcheck:
      test: ["CMD-SHELL", "wget -q --spider http://localhost:8080/api/v1/health || exit 1"]
      start_period: 90s
      interval: 30s
      timeout: 10s
      retries: 5
    deploy:
      resources:
        limits:
          memory: 2G
        reservations:
          memory: 1G

  otel-collector-gateway:
    image: signoz/signoz-otel-collector:{{ signoz_version }}
    restart: unless-stopped
    depends_on:
      clickhouse:
        condition: service_healthy
    # ADR-006: wrapper script authenticates to Infisical and execs original entrypoint
    entrypoint: ["/opt/{{ project_name | replace('-', '_') }}/entrypoint-infisical.sh"]
    command: ["/signoz-otel-collector", "--config=/etc/otel/config.yaml"]
    volumes:
      - ./otel-gateway-config.yaml:/etc/otel/config.yaml:ro
      # ADR-006: bind-mount Infisical CLI + auth file + wrapper script (read-only)
      - /usr/bin/infisical:/usr/bin/infisical:ro
      - /opt/{{ project_name | replace('-', '_') }}/.infisical-auth.env.container:/.infisical-auth.env:ro
      - /opt/{{ project_name | replace('-', '_') }}/entrypoint-infisical.sh:/opt/{{ project_name | replace('-', '_') }}/entrypoint-infisical.sh:ro
    ports:
      - "4317:4317"
      - "4318:4318"
    # CLICKHOUSE_PASSWORD fetched by entrypoint, NOT listed here.
    networks:
      - signoznet
    healthcheck:
      test: ["CMD-SHELL", "wget -q --spider http://localhost:13133/health || exit 1"]
      start_period: 30s
      interval: 15s
      timeout: 5s
      retries: 3
    deploy:
      resources:
        limits:
          memory: 1G
        reservations:
          memory: 512M

  caddy:
    image: {{ caddy_image }}
    restart: unless-stopped
    depends_on:
      signoz:
        condition: service_healthy
    environment:
      DOMAIN: {{ domain }}
    ports:
      - "80:80"
      - "443:443"
      - "443:443/udp"
    volumes:
      - ./Caddyfile:/etc/caddy/Caddyfile:ro
      - caddy_data:/data
      - caddy_config:/config
      # Bind-mount access logs to host so otel-agent's filelog/caddy receiver
      # (mounts /var/log host-side) can read them, and so logs survive container
      # recreation.
      - /var/log/caddy:/var/log/caddy
    networks:
      - signoznet
    deploy:
      resources:
        limits:
          memory: 256M
        reservations:
          memory: 128M

volumes:
  zookeeper_data:
    name: {{ project_name | replace('-', '_') }}_zookeeper_data
  clickhouse_data:
    name: {{ project_name | replace('-', '_') }}_clickhouse_data
  clickhouse_logs:
    name: {{ project_name | replace('-', '_') }}_clickhouse_logs
  signoz_data:
    name: {{ project_name | replace('-', '_') }}_signoz_data
  caddy_data:
    name: {{ project_name | replace('-', '_') }}_caddy_data
  caddy_config:
    name: {{ project_name | replace('-', '_') }}_caddy_config

networks:
  signoznet:
    name: {{ project_name | replace('-', '_') }}_net
    driver: bridge
