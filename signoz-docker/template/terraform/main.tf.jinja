# {{ project_name }} - Main Infrastructure
# Managed by OpenTofu

resource "digitalocean_droplet" "signoz" {
  name       = "{{ project_name }}"
  image      = var.droplet_image
  size       = var.droplet_size
  region     = var.region
  monitoring = true
  backups    = var.enable_skinny_backups ? false : true

  ssh_keys = [var.ssh_key_fingerprint]

  user_data = templatefile("${path.module}/templates/cloud-init.yaml", {
    project_name            = "{{ project_name | replace('-', '_') }}"
    domain                  = var.domain
    signoz_version          = var.signoz_version
    clickhouse_version      = var.clickhouse_version
    zookeeper_version       = var.zookeeper_version
    caddy_image             = var.caddy_image
    infisical_client_id     = var.infisical_client_id
    infisical_client_secret = var.infisical_client_secret
    infisical_project_id    = var.infisical_project_id
    infisical_environment   = var.infisical_environment
    enable_skinny_backups   = var.enable_skinny_backups
    backup_remote_storage   = var.backup_remote_storage
    backup_do_spaces_bucket = var.backup_do_spaces_bucket
    backup_do_spaces_region = var.backup_do_spaces_region
  })

  tags = ["{{ project_name }}", "signoz", "observability", "weown-ai"]

  lifecycle {
    ignore_changes = [user_data]
  }
}

resource "digitalocean_reserved_ip" "signoz" {
  region = var.region
}

resource "digitalocean_reserved_ip_assignment" "signoz" {
  ip_address = digitalocean_reserved_ip.signoz.ip_address
  droplet_id = digitalocean_droplet.signoz.id
}

#trivy:ignore:AVD-DIG-0001  # Public web server: HTTPS inbound for SigNoz UI
#trivy:ignore:AVD-DIG-0003  # Public web server: unrestricted outbound required for OS updates, ACME
resource "digitalocean_firewall" "signoz" {
  name        = "{{ project_name }}-fw"
  droplet_ids = [digitalocean_droplet.signoz.id]

  # SSH
  inbound_rule {
    protocol         = "tcp"
    port_range       = "22"
    source_addresses = ["0.0.0.0/0", "::/0"]
  }

  # HTTP (for ACME challenges and redirects)
  inbound_rule {
    protocol         = "tcp"
    port_range       = "80"
    source_addresses = ["0.0.0.0/0", "::/0"]
  }

  # HTTPS (SigNoz UI)
  inbound_rule {
    protocol         = "tcp"
    port_range       = "443"
    source_addresses = ["0.0.0.0/0", "::/0"]
  }

  # HTTPS/QUIC (HTTP/3)
  inbound_rule {
    protocol         = "udp"
    port_range       = "443"
    source_addresses = ["0.0.0.0/0", "::/0"]
  }

  # OTLP gRPC (fleet OTel agents — VPC only)
  inbound_rule {
    protocol         = "tcp"
    port_range       = "4317"
    source_addresses = ["10.0.0.0/8"]
  }

  # OTLP HTTP (fleet OTel agents — VPC only)
  inbound_rule {
    protocol         = "tcp"
    port_range       = "4318"
    source_addresses = ["10.0.0.0/8"]
  }

  # All outbound TCP
  outbound_rule {
    protocol              = "tcp"
    port_range            = "1-65535"
    destination_addresses = ["0.0.0.0/0", "::/0"]
  }

  # All outbound UDP
  outbound_rule {
    protocol              = "udp"
    port_range            = "1-65535"
    destination_addresses = ["0.0.0.0/0", "::/0"]
  }

  # ICMP for ping/diagnostics
  outbound_rule {
    protocol              = "icmp"
    destination_addresses = ["0.0.0.0/0", "::/0"]
  }

  tags = ["{{ project_name }}"]
}
