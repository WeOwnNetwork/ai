# {{ project_name }} — site-level operator config
# Sourced automatically by deploy.sh, backup.sh, and restore.sh.
# Commit this file. It contains no secrets — only IDs and slugs.
#
# Generated by copier from infisical_project_id + infisical_environment.
# Edit after creating the Infisical app project (step 6.2 in DEPLOYMENT_GUIDE.md).

# The Infisical project ID for THIS site's app secrets
# (SIGNOZ_ADMIN_PASSWORD, CLICKHOUSE_PASSWORD, etc.)
INFISICAL_PROJECT_ID={{ infisical_project_id }}

# Infisical environment slug (prod, staging, dev)
INFISICAL_ENV={{ infisical_environment }}
