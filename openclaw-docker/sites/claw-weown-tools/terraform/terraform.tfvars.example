# claw-weown-tools - Terraform Variables Example
# Copy to terraform.tfvars and fill in real values
# ⚠️ NEVER commit terraform.tfvars to version control
# All application secrets are pulled from Infisical at apply time

infisical_client_id     = "your-infisical-client-id"
infisical_client_secret = "your-infisical-client-secret"
do_token                = "dop_v1_xxxxxxxxxxxxxxxxxxxx"
ssh_key_fingerprint     = "aa:bb:cc:dd:ee:ff:00:11:22:33:44:55:66:77:88:99"

# Optional overrides (defaults shown)
region       = "nyc1"
droplet_size = "s-2vcpu-2gb-amd"
alert_email  = "MWK@weown.net"
