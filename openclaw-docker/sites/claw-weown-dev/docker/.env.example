# claw-weown-dev - Environment Variables Example (local dev)
#
# Copy to .env.local for local docker-compose:
#   cp .env.example .env.local
#   docker compose -f compose.local.yaml up
#
# For real secret values locally, use Infisical CLI instead of editing .env.local:
#   infisical run --env=dev -- docker compose -f compose.local.yaml up
#
# Required Infisical secrets (production deploys NEVER use this file):
#   OPENCLAW_GATEWAY_TOKEN  (OpenClaw API auth)
#   OPENROUTER_API_KEY      (LLM inference via OpenRouter)
#   SIGNOZ_INGESTION_KEY    (OTel telemetry to SigNoz Cloud)
#
# Only the Infisical Machine Identity (Client ID + Client Secret)
# lives on production hosts — everything else comes from Infisical.

# Domain (non-sensitive — can stay here or move to Infisical)
DOMAIN=claw.weown.dev

# Container Images (non-sensitive)
OPENCLAW_IMAGE=reg.mini.dev/openclaw:2026.6.1
CADDY_IMAGE=reg.mini.dev/caddy:2

# OpenClaw Internal Port (non-sensitive)
OPENCLAW_INTERNAL_PORT=18789

# OpenTelemetry — point at SigNoz Cloud or your local OTel collector
OTEL_EXPORTER_OTLP_ENDPOINT=

# Application secrets — DO NOT put real values here for local dev;
# use `infisical run --env=dev` instead.
OPENCLAW_GATEWAY_TOKEN=
OPENROUTER_API_KEY=
SIGNOZ_INGESTION_KEY=
PROXY_SERVER=

# Infisical Configuration (Machine Identity only)
INFISICAL_CLIENT_ID=your-client-id
INFISICAL_CLIENT_SECRET=your-client-secret
INFISICAL_PROJECT_ID=6c05dbb2-dc9f-41a8-8b4d-d50d515115e8
INFISICAL_ENVIRONMENT=prod
