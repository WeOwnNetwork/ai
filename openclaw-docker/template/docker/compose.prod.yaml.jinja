# {{ project_name }} - Docker Compose (ADR-006: In-Container Infisical Injection)
# Secrets are fetched IN-PROCESS by the container at startup via `infisical run` entrypoint.
# A `docker restart` re-fetches secrets (bounce-to-refresh). No secrets in environment: block.
# No secrets should be stored in this file or in .env files on disk.
#
# Required Infisical secrets:
#   OPENCLAW_GATEWAY_TOKEN  (OpenClaw API auth)
#   OPENROUTER_API_KEY      (LLM inference via OpenRouter)
#   SIGNOZ_INGESTION_KEY    (OTel telemetry to SigNoz Cloud)
# Optional Infisical secrets:
#   PROXY_SERVER            (HTTP proxy for outbound traffic)

services:
  openclaw:
    image: {{ openclaw_image }}
    restart: unless-stopped
    # ADR-006: wrapper script authenticates to Infisical and execs original entrypoint
    entrypoint: ["/opt/{{ project_name | replace('-', '_') }}/entrypoint-infisical.sh"]
    command: ["node", "dist/index.js"]
    # Hardening (security audit 2026-06-26, M1): the internet-facing app should
    # not run with default Docker capabilities. OpenClaw listens on an
    # unprivileged port ({{ openclaw_internal_port }} > 1024) so it needs no
    # added caps. If a smoke test surfaces a missing-capability error, add the
    # one specific cap under cap_add — do NOT drop cap_drop: ALL.
    security_opt:
      - no-new-privileges:true
    cap_drop:
      - ALL
    environment:
      # Application config (non-secret only; secrets fetched by entrypoint)
      OTEL_SERVICE_NAME: "{{ project_name }}"
      OTEL_EXPORTER_OTLP_ENDPOINT: "https://ingest.us2.signoz.cloud:443"
      OTEL_EXPORTER_OTLP_PROTOCOL: "http/protobuf"
      # Secrets (OPENCLAW_GATEWAY_TOKEN, OPENROUTER_API_KEY, SIGNOZ_INGESTION_KEY,
      # PROXY_SERVER) fetched by entrypoint, NOT listed here.
    volumes:
      - openclaw_data:/home/node/.openclaw
      - openclaw_workspace:/home/node/openclaw/workspace
      # ADR-006: bind-mount Infisical CLI + auth file + wrapper script (read-only)
      - /usr/bin/infisical:/usr/bin/infisical:ro
      - /opt/{{ project_name | replace('-', '_') }}/.infisical-auth.env.container:/.infisical-auth.env:ro
      - /opt/{{ project_name | replace('-', '_') }}/entrypoint-infisical.sh:/opt/{{ project_name | replace('-', '_') }}/entrypoint-infisical.sh:ro
    networks:
      - openclawnet
    healthcheck:
      # HTTP healthcheck — OpenClaw exposes /healthz returning 200.
      test: ["CMD-SHELL", "curl -sf http://127.0.0.1:{{ openclaw_internal_port }}/healthz || exit 1"]
      start_period: 30s
      interval: 30s
      timeout: 5s
      retries: 5
    deploy:
      resources:
        limits:
          memory: 2G
          cpus: "2"
        reservations:
          memory: 1G
          cpus: "1"

  caddy:
    image: {{ caddy_image }}
    restart: unless-stopped
    depends_on:
      openclaw:
        condition: service_healthy
    environment:
      DOMAIN: {{ domain }}
    # Hardening (§3.8): drop all caps then add only NET_BIND_SERVICE so Caddy
    # can bind :80/:443 as non-root; no-new-privileges blocks setuid escalation.
    cap_drop:
      - ALL
    cap_add:
      - NET_BIND_SERVICE
    security_opt:
      - no-new-privileges:true
    ports:
      - "80:80"
      - "443:443"
      - "443:443/udp"
    volumes:
      - ./Caddyfile:/etc/caddy/Caddyfile:ro
      - caddy_data:/data
      - caddy_config:/config
      # Bind-mount Caddy access logs so otel-agent (filelog/caddy receiver)
      # can read them. Matches `output file /var/log/caddy/...` in Caddyfile.
      - /var/log/caddy:/var/log/caddy
    networks:
      - openclawnet
    healthcheck:
      test: ["CMD-SHELL", "wget --no-verbose --tries=1 --spider http://127.0.0.1:80 || exit 1"]
      start_period: 10s
      interval: 30s
      timeout: 5s
      retries: 3
    deploy:
      resources:
        limits:
          memory: 256M
        reservations:
          memory: 128M

volumes:
  openclaw_data:
    name: {{ project_name | replace('-', '_') }}_data
  openclaw_workspace:
    name: {{ project_name | replace('-', '_') }}_workspace
  caddy_data:
    name: {{ project_name | replace('-', '_') }}_caddy_data
  caddy_config:
    name: {{ project_name | replace('-', '_') }}_caddy_config

networks:
  openclawnet:
    name: {{ project_name | replace('-', '_') }}_net
    driver: bridge
