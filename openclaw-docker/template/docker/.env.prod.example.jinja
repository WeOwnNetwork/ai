# {{ project_name }} - Production Environment Variables EXAMPLE
#
# WARNING: This is an EXAMPLE file. NEVER write real secrets to disk.
# Production secrets (OPENCLAW_GATEWAY_TOKEN, OPENROUTER_API_KEY,
# SIGNOZ_INGESTION_KEY) are injected at container startup via `infisical run`
# and never persisted. The only credential on disk is the Infisical Machine
# Identity at /opt/{{ project_name | replace('-', '_') }}/.infisical-auth.env
# (0600 root, rotated on first boot via rotate-bootstrap-secret.sh — see
# Layer 2 in docs/INFRA_BOOTSTRAP_PATTERN.md).

# Domain (non-sensitive)
DOMAIN={{ domain }}

# Container Images (non-sensitive)
OPENCLAW_IMAGE={{ openclaw_image }}
CADDY_IMAGE={{ caddy_image }}

# OpenClaw Internal Port (non-sensitive)
OPENCLAW_INTERNAL_PORT={{ openclaw_internal_port }}

# OpenTelemetry destination (non-sensitive endpoint URL — key is from Infisical)
OTEL_EXPORTER_OTLP_ENDPOINT=https://ingest.us2.signoz.cloud:443

# Application secrets — DO NOT put real values here. They are injected at
# container startup via `infisical run -- docker compose up -d` and live
# in the Infisical project, not on disk.
#   OPENCLAW_GATEWAY_TOKEN  (required)  OpenClaw API auth
#   OPENROUTER_API_KEY      (required)  LLM inference via OpenRouter
#   SIGNOZ_INGESTION_KEY    (required)  OTel telemetry to SigNoz Cloud
#   PROXY_SERVER            (optional)  HTTP proxy for outbound traffic

# Infisical environment selector (used by `infisical run --env=...`).
# Machine Identity client_id/client_secret are NOT here — they live in
# /opt/{{ project_name | replace('-', '_') }}/.infisical-auth.env.
INFISICAL_PROJECT_ID={{ infisical_project_id | default('') }}
INFISICAL_ENVIRONMENT={{ infisical_environment | default('prod') }}
