# Global options (security audit 2026-06-26, L2): disable the Caddy admin API.
# This is a static-config deployment — the admin endpoint is unused attack surface.
{
    admin off
}

{{ domain }} {
    reverse_proxy openclaw:{{ openclaw_internal_port }} {
        flush_interval -1
    }
    log {

        # Write to the host-bind-mounted /var/log/caddy/ so otel-agent's
        # filelog/caddy receiver can read this and so logs survive container
        # recreation. See docker/compose.prod.yaml caddy.volumes for the mount.
        output file /var/log/caddy/{{ project_name }}.log
    }
    header {

        # HSTS — force HTTPS for a year incl. subdomains (security audit L2).
        Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
        X-Content-Type-Options nosniff
        X-Frame-Options SAMEORIGIN
        # X-XSS-Protection is deprecated and can introduce vulns in legacy
        # browsers; set 0 and rely on CSP / framework escaping (audit L2).
        X-XSS-Protection "0"
        Referrer-Policy strict-origin-when-cross-origin
        -Server
    }
}
