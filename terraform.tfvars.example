# OpenTofu WordPress + Infisical Template
# Copy this file to terraform.tfvars and fill in real values.
# NEVER commit terraform.tfvars.

# =============================================================================
# DigitalOcean
# =============================================================================
do_token            = "dop_v1_xxxxxxxxxxxxxxxxxxxx"
ssh_key_fingerprint = "aa:bb:cc:dd:ee:ff:00:11:22:33:44:55:66:77:88:99"

# =============================================================================
# Project / Site
# =============================================================================
project_name = "example-site"
domain       = "example.com"
domain_style = "apex"

region       = "nyc3"
droplet_size = "s-2vcpu-2gb-amd"

# =============================================================================
# SSH
# =============================================================================
private_key_path = "~/.ssh/id_ed25519"

# =============================================================================
# Container Images
# =============================================================================
wp_image        = "wordpress:php8.3-fpm"
caddy_image     = "caddy:2"
mariadb_version = "11"

# =============================================================================
# Database
# =============================================================================
mysql_database      = "wordpress"
mysql_user          = "wordpress"
mysql_password      = "CHANGE_ME_STRONG_PASSWORD"
mysql_root_password = "CHANGE_ME_STRONG_ROOT_PASSWORD"

# =============================================================================
# Infisical
# =============================================================================
enable_infisical      = true
infisical_client_id   = "YOUR_INFISICAL_CLIENT_ID"
infisical_client_secret = "YOUR_INFISICAL_CLIENT_SECRET"
infisical_project_id  = "YOUR_INFISICAL_PROJECT_ID"
infisical_environment = "dev"

# Change this value when you want OpenTofu to rotate secrets
secret_rotation_version = "v1"

# =============================================================================
# Monitoring
# =============================================================================
alert_email            = "admin@example.com"
cpu_alert_threshold    = 80
memory_alert_threshold = 90
disk_alert_threshold   = 85
