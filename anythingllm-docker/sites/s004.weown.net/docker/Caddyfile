# int-s004-anythingllm — Caddyfile
# Reverse proxy for AnythingLLM on s004.weown.net (INT-S004 rebuild).
#
# Single-hostname by design. `s004.weown.net` is the new standard FQDN for
# INT-S004; it is brand new (no prior traffic), so there is nothing to "cut
# over" — pointing its A record at this droplet IS go-live. The legacy
# `s004.ccc.bot` name is deliberately NOT served here:
#   - a repo-wide audit found nothing routes to it (only self-references in the
#     retired sites/s004/ folder and historical prose), and
#   - the old box is locked out, so there is no live s004.ccc.bot traffic to
#     preserve.
# See ../MIGRATION_RUNBOOK.md "Hostname decision (verified)".
#
# Escape hatch: if an external consumer of s004.ccc.bot ever surfaces, change
# the site line to `s004.weown.net, s004.ccc.bot {` and re-run
# ./scripts/deploy.sh. Caddy fetches the new Let's Encrypt cert on first
# request after DNS resolves — no tofu taint, no downtime (Path C: the
# Caddyfile is ansible-owned, not baked into cloud-init).

s004.weown.net {
    reverse_proxy anythingllm:3001 {
        flush_interval -1
    }
    log {
        # Write to the host-bind-mounted /var/log/caddy/ so otel-agent's
        # filelog/caddy receiver can read this and so logs survive container
        # recreation. See docker/compose.prod.yaml caddy.volumes for the mount.
        output file /var/log/caddy/int-s004-anythingllm.log
    }
    header {
        X-Content-Type-Options nosniff
        X-Frame-Options SAMEORIGIN
        X-XSS-Protection "1; mode=block"
        Referrer-Policy strict-origin-when-cross-origin
        -Server
    }
}
