{
  "mcpServers": {
    "searxng": {
      "command": "node",
      "args": ["/app/server/storage/mcp/searxng/index.js"],
      "env": {
        "SEARXNG_BASE_URL": "https://searxng.weown.app/"
      },
      "enabled": true
    },
    "web-scraping": {
      "command": "node",
      "args": ["/app/server/storage/mcp/puppeteer/index.js"],
      "enabled": true
    },
    "web-browsing": {
      "command": "node",
      "args": ["/app/server/storage/mcp/fetch/index.js"],
      "enabled": true
    },
    "rag-memory": {
      "command": "node",
      "args": ["/app/server/storage/mcp/lancedb/index.js"],
      "enabled": true
    },
    "document-summarizer": {
      "command": "node",
      "args": ["/app/server/storage/mcp/summarizer/index.js"],
      "enabled": true
    }
  }
}
