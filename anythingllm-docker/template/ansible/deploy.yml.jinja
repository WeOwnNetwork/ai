---
# {{ project_name }} — Idempotent deployment playbook (Path C app layer)
#
# This playbook owns ALL post-bootstrap state on the droplet. Cloud-init only
# handles first-boot bootstrap (Docker, Infisical CLI, .infisical-auth.env,
# bootstrap-secret rotation). Everything else lives here so ongoing changes
# don't require `tofu taint` (which would destroy + recreate the droplet).
#
# What this playbook manages:
#   - compose.yaml (uploaded from docker/compose.prod.yaml)
#   - Caddyfile    (uploaded from docker/Caddyfile)
#   - backup.sh    (uploaded from scripts/backup.sh)
#   - daily backup cron + logrotate
#   - docker compose up (reconciled — bounced if any uploaded file changed)
#   - DO droplet tagging: feature tags (skinny-backup) + commit tag (commit-<sha>)
#
# Pre-conditions enforced:
#   - The droplet must have completed cloud-init (.bootstrap-complete exists)
#   - INFISICAL_PROJECT_ID must be set in the environment
#   - doctl must be authenticated locally (for tag updates)
#
# Usage:
#   INFISICAL_PROJECT_ID=<id> ansible-playbook -i 'root@<droplet-ip>,' \
#     {{ project_name }}/ansible/deploy.yml
#
#   Or use the wrapper: scripts/deploy.sh root@<droplet-ip>

- name: Deploy {{ project_name }} app layer
  hosts: all
  gather_facts: false
  become: true
  vars:
    app_dir: /opt/{{ project_name | replace('-', '_') }}
    infisical_project_id: "{{ '{{' }} lookup('env', 'INFISICAL_PROJECT_ID') {{ '}}' }}"
    infisical_env: "{{ '{{' }} lookup('env', 'INFISICAL_ENV') | default('prod', True) {{ '}}' }}"
    droplet_name: "{{ project_name }}"
    git_commit_short: "{{ '{{' }} lookup('pipe', 'git rev-parse --short HEAD 2>/dev/null || echo unknown') {{ '}}' }}"
    anythingllm_image: {{ anythingllm_image }}
    caddy_image: {{ caddy_image }}

  pre_tasks:
    - name: Require INFISICAL_PROJECT_ID env var
      ansible.builtin.assert:
        that:
          - infisical_project_id | length > 0
        fail_msg: >-
          INFISICAL_PROJECT_ID env var is required. This is the same value
          as terraform.tfvars infisical_project_id. Run:
          INFISICAL_PROJECT_ID=<id> ansible-playbook ...

    - name: Verify droplet has completed cloud-init bootstrap
      ansible.builtin.stat:
        path: "{{ '{{' }} app_dir {{ '}}' }}/.bootstrap-complete"
      register: bootstrap_marker

    - name: Fail clearly if bootstrap is not complete
      ansible.builtin.fail:
        msg: >-
          {{ '{{' }} app_dir {{ '}}' }}/.bootstrap-complete is missing — droplet
          has not finished cloud-init. Wait a few minutes after `tofu apply`
          and retry. Check /var/log/cloud-init-output.log on the droplet for
          errors.
      when: not bootstrap_marker.stat.exists

    - name: Verify Infisical auth file exists (created by cloud-init)
      ansible.builtin.stat:
        path: "{{ '{{' }} app_dir {{ '}}' }}/.infisical-auth.env"
      register: auth_file

    - name: Fail clearly if auth file is missing
      ansible.builtin.fail:
        msg: >-
          {{ '{{' }} app_dir {{ '}}' }}/.infisical-auth.env is missing —
          Infisical Machine Identity bootstrap failed. Check
          /var/log/cloud-init-output.log and
          /var/log/{{ project_name | replace('-', '_') }}-rotation.log.
      when: not auth_file.stat.exists

  tasks:
    - name: Upload compose.yaml
      ansible.builtin.copy:
        src: ../docker/compose.prod.yaml
        dest: "{{ '{{' }} app_dir {{ '}}' }}/compose.yaml"
        owner: root
        group: root
        mode: "0644"
      notify: Reconcile docker compose stack

    - name: Upload Caddyfile
      ansible.builtin.copy:
        src: ../docker/Caddyfile
        dest: "{{ '{{' }} app_dir {{ '}}' }}/Caddyfile"
        owner: root
        group: root
        mode: "0644"
      notify: Reconcile docker compose stack

    - name: Upload backup script
      ansible.builtin.copy:
        src: ../scripts/backup.sh
        dest: "{{ '{{' }} app_dir {{ '}}' }}/backup.sh"
        owner: root
        group: root
        mode: "0750"

    - name: Install daily backup cron (wraps backup.sh with Infisical injection)
      ansible.builtin.copy:
        content: |
          #!/bin/bash
          # Daily backup with Infisical runtime secret injection. Managed by
          # {{ project_name }}/ansible/deploy.yml — edit there, not here.
          set -euo pipefail
          # shellcheck disable=SC1091
          source {{ '{{' }} app_dir {{ '}}' }}/.infisical-auth.env
          infisical login --method=universal-auth \
            --clientId="$INFISICAL_CLIENT_ID" \
            --clientSecret="$INFISICAL_CLIENT_SECRET" \
            --silent
          infisical run \
            --projectId={{ '{{' }} infisical_project_id {{ '}}' }} \
            --env={{ '{{' }} infisical_env {{ '}}' }} \
            -- {{ '{{' }} app_dir {{ '}}' }}/backup.sh \
            >> /var/log/{{ project_name | replace('-', '_') }}-backup.log 2>&1
        dest: /etc/cron.daily/{{ project_name | replace('-', '_') }}-backup
        owner: root
        group: root
        mode: "0750"

    - name: Ensure logrotate config for backup log
      ansible.builtin.copy:
        content: |
          # Managed by {{ project_name }}/ansible/deploy.yml — do not edit on host.
          /var/log/{{ project_name | replace('-', '_') }}-backup.log {
            weekly
            rotate 12
            compress
            missingok
            notifempty
            create 0640 root root
          }
        dest: /etc/logrotate.d/{{ project_name | replace('-', '_') }}-backup
        owner: root
        group: root
        mode: "0644"

    # ─── Team SSH access (root authorized_keys, managed from Infisical) ──────
    # Devs SSH in as root to operate this box. Their PUBLIC keys live in the
    # Infisical OPS_AUTHORIZED_KEYS var (one key per line) — the single source
    # of truth. We write them to a SEPARATE file managed exclusively here; the
    # DO-registered break-glass key in .ssh/authorized_keys is never touched
    # (no lock-out risk). Add/remove a key in Infisical + re-run deploy.sh to
    # grant/revoke (revoke = delete the line, e.g. on termination).
    - name: Configure sshd to read the managed team-ops keys file (+ break-glass)
      ansible.builtin.copy:
        content: |
          # Managed by {{ project_name }}/ansible/deploy.yml — do not edit on host.
          # Break-glass key stays in .ssh/authorized_keys; team keys live in
          # .ssh/authorized_keys.weown-ops (from Infisical OPS_AUTHORIZED_KEYS).
          AuthorizedKeysFile .ssh/authorized_keys .ssh/authorized_keys.weown-ops
        dest: /etc/ssh/sshd_config.d/10-weown-ops-keys.conf
        owner: root
        group: root
        mode: "0644"
      notify: Reload sshd

    - name: Sync team ops SSH keys to root (from Infisical OPS_AUTHORIZED_KEYS)
      ansible.builtin.shell: |
        set -euo pipefail
        # shellcheck disable=SC1091
        source {{ '{{' }} app_dir {{ '}}' }}/.infisical-auth.env
        infisical login --method=universal-auth \
          --clientId="$INFISICAL_CLIENT_ID" \
          --clientSecret="$INFISICAL_CLIENT_SECRET" \
          --silent
        install -d -m 0700 -o root -g root /root/.ssh
        infisical run --projectId={{ '{{' }} infisical_project_id {{ '}}' }} --env={{ '{{' }} infisical_env {{ '}}' }} -- bash -c '
          keys="${OPS_AUTHORIZED_KEYS:-}"
          if [ -z "$keys" ]; then
            echo "WARN: OPS_AUTHORIZED_KEYS not set in Infisical; leaving team keys unchanged."
            exit 0
          fi
          umask 077
          printf "%s\n" "$keys" | grep -vE "^[[:space:]]*$" > /root/.ssh/authorized_keys.weown-ops
          chown root:root /root/.ssh/authorized_keys.weown-ops
          chmod 600 /root/.ssh/authorized_keys.weown-ops
          echo "synced $(grep -c . /root/.ssh/authorized_keys.weown-ops) team key(s)"
        '
      args:
        executable: /bin/bash
      register: ops_keys_sync
      changed_when: "'synced' in ops_keys_sync.stdout"

    - name: Pull container images
      # Use docker_image_pull (CLI-based, no python3-docker SDK required on
      # the droplet) instead of docker_image (which needs the Python SDK).
      # Cloud-init only installs Docker itself, not the SDK.
      community.docker.docker_image_pull:
        name: "{{ '{{' }} item {{ '}}' }}"
      loop:
        - "{{ '{{' }} anythingllm_image {{ '}}' }}"
        - "{{ '{{' }} caddy_image {{ '}}' }}"
      register: image_pull
      retries: 3
      delay: 5
      until: image_pull is succeeded

    - name: Ensure compose stack is running (idempotent — `up -d` is a no-op if nothing changed)
      ansible.builtin.shell: |
        set -euo pipefail
        # shellcheck disable=SC1091
        source {{ '{{' }} app_dir {{ '}}' }}/.infisical-auth.env
        infisical login --method=universal-auth \
          --clientId="$INFISICAL_CLIENT_ID" \
          --clientSecret="$INFISICAL_CLIENT_SECRET" \
          --silent
        cd {{ '{{' }} app_dir {{ '}}' }}
        infisical run \
          --projectId={{ '{{' }} infisical_project_id {{ '}}' }} \
          --env={{ '{{' }} infisical_env {{ '}}' }} \
          -- docker compose up -d --remove-orphans
      args:
        executable: /bin/bash
      register: compose_up
      changed_when: "'Started' in compose_up.stderr or 'Created' in compose_up.stderr or 'Recreated' in compose_up.stderr"

    - name: Wait for AnythingLLM health
      ansible.builtin.uri:
        url: http://127.0.0.1:3001/api/ping
        status_code: 200
      register: health_probe
      retries: 20
      delay: 5
      until: health_probe.status == 200

    # ─── DO droplet tagging ──────────────────────────────────────────────
    # After a successful deploy, update droplet tags to reflect actual state:
    # - skinny-backup tag (we just configured the cron)
    # - commit-<sha> tag (which git commit produced this deployment)
    # See docs/INFRA_BOOTSTRAP_PATTERN.md "DO tag taxonomy" for the full scheme.
    # Tags are mutated via the shared scripts/tag-droplet.sh helper; ansible
    # runs it locally via delegate_to.

    - name: Update DO droplet tags (skinny-backup + commit-<sha>)
      ansible.builtin.shell: |
        set -euo pipefail
        scripts/tag-droplet.sh "{{ '{{' }} droplet_name {{ '}}' }}" \
          replace-prefix commit- "commit-{{ '{{' }} git_commit_short {{ '}}' }}" \
          add skinny-backup
      args:
        executable: /bin/bash
        # Walk up to the WeOwn repo root so `scripts/tag-droplet.sh` resolves.
        # Layout: <repo-root>/anythingllm-docker/sites/<name>/ansible/deploy.yml
        #   playbook_dir         = …/anythingllm-docker/sites/<name>/ansible
        #   dirname × 4          = <repo-root>
        chdir: "{{ '{{' }} playbook_dir | dirname | dirname | dirname | dirname {{ '}}' }}"
      delegate_to: localhost
      become: false
      changed_when: false
      failed_when: false   # Tagging failure must not block the deploy

    - name: Report success
      ansible.builtin.debug:
        msg: >-
          {{ project_name }} app layer deployed (commit
          {{ '{{' }} git_commit_short {{ '}}' }}).
          URL: https://{{ domain }}/

  handlers:
    - name: Reconcile docker compose stack
      ansible.builtin.shell: |
        set -euo pipefail
        # shellcheck disable=SC1091
        source {{ '{{' }} app_dir {{ '}}' }}/.infisical-auth.env
        infisical login --method=universal-auth \
          --clientId="$INFISICAL_CLIENT_ID" \
          --clientSecret="$INFISICAL_CLIENT_SECRET" \
          --silent
        cd {{ '{{' }} app_dir {{ '}}' }}
        infisical run \
          --projectId={{ '{{' }} infisical_project_id {{ '}}' }} \
          --env={{ '{{' }} infisical_env {{ '}}' }} \
          -- docker compose up -d --force-recreate --remove-orphans
      args:
        executable: /bin/bash
      changed_when: false

    - name: Reload sshd
      # `sshd -t` validates the FULL config (incl. the drop-in) before reload;
      # if it fails we do NOT reload, so the running (working) sshd is untouched.
      ansible.builtin.shell: |
        set -euo pipefail
        sshd -t
        systemctl reload ssh 2>/dev/null || systemctl reload sshd
      args:
        executable: /bin/bash
      changed_when: false
