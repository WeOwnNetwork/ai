---
# {{ project_name }} — Idempotent deployment playbook (Path C app layer)
#
# This playbook owns ALL post-bootstrap state on the droplet. Cloud-init only
# handles first-boot bootstrap (Docker, Infisical CLI, .infisical-auth.env,
# bootstrap-secret rotation). Everything else lives here so ongoing changes
# don't require `tofu taint` (which would destroy + recreate the droplet).
#
# What this playbook manages:
#   - compose.yaml (uploaded from docker/compose.prod.yaml)
#   - Caddyfile    (uploaded from docker/Caddyfile)
#   - backup.sh    (uploaded from scripts/backup.sh)
#   - daily backup cron + logrotate
#   - docker compose up (reconciled — bounced if any uploaded file changed)
#   - DO droplet tagging: feature tags (skinny-backup) + commit tag (commit-<sha>)
#
# Pre-conditions enforced:
#   - The droplet must have completed cloud-init (.bootstrap-complete exists)
#   - INFISICAL_PROJECT_ID must be set in the environment
#   - doctl must be authenticated locally (for tag updates)
#
# Usage:
#   INFISICAL_PROJECT_ID=<id> ansible-playbook -i 'root@<droplet-ip>,' \
#     {{ project_name }}/ansible/deploy.yml
#
#   Or use the wrapper: scripts/deploy.sh root@<droplet-ip>

- name: Deploy {{ project_name }} app layer
  hosts: all
  gather_facts: false
  become: true
  vars:
    app_dir: /opt/{{ project_name | replace('-', '_') }}
    infisical_project_id: "{{ '{{' }} lookup('env', 'INFISICAL_PROJECT_ID') {{ '}}' }}"
    infisical_env: "{{ '{{' }} lookup('env', 'INFISICAL_ENV') | default('prod', True) {{ '}}' }}"
    infisical_path: "{{ '{{' }} lookup('env', 'INFISICAL_PATH') | default('/', True) {{ '}}' }}"
    droplet_name: "{{ project_name }}"
    git_commit_short: "{{ '{{' }} lookup('pipe', 'git rev-parse --short HEAD 2>/dev/null || echo unknown') {{ '}}' }}"
    caddy_image: {{ caddy_image }}

  pre_tasks:
    - name: Require INFISICAL_PROJECT_ID env var
      ansible.builtin.assert:
        that:
          - infisical_project_id | length > 0
        fail_msg: >-
          INFISICAL_PROJECT_ID env var is required. This is the same value
          as terraform.tfvars infisical_project_id. Run:
          INFISICAL_PROJECT_ID=<id> ansible-playbook ...

    - name: Verify droplet has completed cloud-init bootstrap
      ansible.builtin.stat:
        path: "{{ '{{' }} app_dir {{ '}}' }}/.bootstrap-complete"
      register: bootstrap_marker

    - name: Fail clearly if bootstrap is not complete
      ansible.builtin.fail:
        msg: >-
          {{ '{{' }} app_dir {{ '}}' }}/.bootstrap-complete is missing — droplet
          has not finished cloud-init. Wait a few minutes after `tofu apply`
          and retry. Check /var/log/cloud-init-output.log on the droplet for
          errors.
      when: not bootstrap_marker.stat.exists

    - name: Verify Infisical auth file exists (created by cloud-init)
      ansible.builtin.stat:
        path: "{{ '{{' }} app_dir {{ '}}' }}/.infisical-auth.env"
      register: auth_file

    - name: Fail clearly if auth file is missing
      ansible.builtin.fail:
        msg: >-
          {{ '{{' }} app_dir {{ '}}' }}/.infisical-auth.env is missing —
          Infisical Machine Identity bootstrap failed. Check
          /var/log/cloud-init-output.log and
          /var/log/{{ project_name | replace('-', '_') }}-rotation.log.
      when: not auth_file.stat.exists

    - name: Check for Machine Identity rotation failure (Layer 2 bootstrap)
      ansible.builtin.stat:
        path: "{{ '{{' }} app_dir {{ '}}' }}/.rotation-failed"
      register: rotation_failed_marker

    - name: Check for Machine Identity rotation success
      ansible.builtin.stat:
        path: "{{ '{{' }} app_dir {{ '}}' }}/.rotation-complete"
      register: rotation_complete_marker

    - name: Warn loudly if bootstrap-secret rotation failed
      ansible.builtin.debug:
        msg: >-
          ⚠️  WARNING: Machine Identity bootstrap-secret rotation FAILED on
          this droplet (see {{ '{{' }} app_dir {{ '}}' }}/.rotation-failed and
          /var/log/{{ project_name | replace('-', '_') }}-rotation.log).
          The droplet is still running on its v1 bootstrap secret, which is
          less secure (it briefly existed in Terraform state). This does NOT
          block deployment, but should be fixed via the manual rotation
          runbook in README.md — typically by granting the Machine Identity
          'manage own client secrets' permission in Infisical.
      when: rotation_failed_marker.stat.exists and not rotation_complete_marker.stat.exists

  tasks:
    - name: Upload compose.yaml
      ansible.builtin.copy:
        src: ../docker/compose.prod.yaml
        dest: "{{ '{{' }} app_dir {{ '}}' }}/compose.yaml"
        owner: root
        group: root
        mode: "0644"
      notify: Reconcile docker compose stack

    - name: Upload Caddyfile
      ansible.builtin.copy:
        src: ../docker/Caddyfile
        dest: "{{ '{{' }} app_dir {{ '}}' }}/Caddyfile"
        owner: root
        group: root
        mode: "0644"
      notify: Reconcile docker compose stack

    - name: Upload customer dashboard app (zero-dep Node; bind-mounted ro into the dashboard container)
      ansible.builtin.copy:
        src: ../dashboard/
        dest: "{{ '{{' }} app_dir {{ '}}' }}/dashboard/"
        owner: root
        group: root
        mode: "0644"
        directory_mode: "0755"
      notify: Reconcile docker compose stack

    - name: Upload backup script
      ansible.builtin.copy:
        src: ../scripts/backup.sh
        dest: "{{ '{{' }} app_dir {{ '}}' }}/backup.sh"
        owner: root
        group: root
        mode: "0750"

    - name: Upload restore script
      # restore.sh remote mode re-execs {{ '{{' }} app_dir {{ '}}' }}/restore.sh on the droplet,
      # so it must exist there for the documented DO-Spaces / skinny-backup restore.
      ansible.builtin.copy:
        src: ../scripts/restore.sh
        dest: "{{ '{{' }} app_dir {{ '}}' }}/restore.sh"
        owner: root
        group: root
        mode: "0750"

    - name: Upload Infisical entrypoint wrapper (ADR-006)
      # This script authenticates to Infisical and execs the original entrypoint.
      # It is bind-mounted read-only into the container as the container entrypoint.
      ansible.builtin.copy:
        src: ../scripts/entrypoint-infisical.sh
        dest: "{{ '{{' }} app_dir {{ '}}' }}/entrypoint-infisical.sh"
        owner: root
        group: root
        mode: "0750"

    - name: Install daily backup cron (wraps backup.sh with Infisical injection)
      ansible.builtin.copy:
        content: |
          #!/bin/bash
          # Daily backup with Infisical runtime secret injection. Managed by
          # {{ project_name }}/ansible/deploy.yml — edit there, not here.
          set -euo pipefail
          # shellcheck disable=SC1091
          source {{ '{{' }} app_dir {{ '}}' }}/.infisical-auth.env
          export INFISICAL_UNIVERSAL_AUTH_CLIENT_ID="$INFISICAL_CLIENT_ID"
          export INFISICAL_UNIVERSAL_AUTH_CLIENT_SECRET="$INFISICAL_CLIENT_SECRET"
          export INFISICAL_TOKEN="$(infisical login --method=universal-auth --plain --silent)"
          infisical run \
            --projectId={{ '{{' }} infisical_project_id {{ '}}' }} \
            --env={{ '{{' }} infisical_env {{ '}}' }} --path={{ '{{' }} infisical_path {{ '}}' }} \
            -- {{ '{{' }} app_dir {{ '}}' }}/backup.sh \
            >> /var/log/{{ project_name | replace('-', '_') }}-backup.log 2>&1
        dest: /etc/cron.daily/{{ project_name | replace('-', '_') }}-backup
        owner: root
        group: root
        mode: "0750"

    - name: Ensure logrotate config for backup log
      ansible.builtin.copy:
        content: |
          # Managed by {{ project_name }}/ansible/deploy.yml — do not edit on host.
          /var/log/{{ project_name | replace('-', '_') }}-backup.log {
            weekly
            rotate 12
            compress
            missingok
            notifempty
            create 0640 root root
          }
        dest: /etc/logrotate.d/{{ project_name | replace('-', '_') }}-backup
        owner: root
        group: root
        mode: "0644"

    # ─── Team SSH access (root authorized_keys, managed from Infisical) ──────
    # Devs SSH in as root to operate this box. Their PUBLIC keys live in the
    # Infisical OPS_AUTHORIZED_KEYS var (one key per line) — the single source
    # of truth. We write them to a SEPARATE file managed exclusively here; the
    # DO-registered break-glass key in .ssh/authorized_keys is never touched
    # (no lock-out risk). Add/remove a key in Infisical + re-run deploy.sh to
    # grant/revoke (revoke = delete the line, e.g. on termination).
    - name: Configure sshd to read the managed team-ops keys file (+ break-glass)
      ansible.builtin.copy:
        content: |
          # Managed by {{ project_name }}/ansible/deploy.yml — do not edit on host.
          # Break-glass key stays in .ssh/authorized_keys; team keys live in
          # .ssh/authorized_keys.weown-ops (from Infisical OPS_AUTHORIZED_KEYS).
          AuthorizedKeysFile .ssh/authorized_keys .ssh/authorized_keys.weown-ops
        dest: /etc/ssh/sshd_config.d/10-weown-ops-keys.conf
        owner: root
        group: root
        mode: "0644"
      notify: Reload sshd

    - name: Sync team ops SSH keys to root (from Infisical OPS_AUTHORIZED_KEYS)
      ansible.builtin.shell: |
        set -euo pipefail
        # shellcheck disable=SC1091
        source {{ '{{' }} app_dir {{ '}}' }}/.infisical-auth.env
        export INFISICAL_UNIVERSAL_AUTH_CLIENT_ID="$INFISICAL_CLIENT_ID"
        export INFISICAL_UNIVERSAL_AUTH_CLIENT_SECRET="$INFISICAL_CLIENT_SECRET"
        export INFISICAL_TOKEN="$(infisical login --method=universal-auth --plain --silent)"
        install -d -m 0700 -o root -g root /root/.ssh
        infisical run --projectId={{ '{{' }} infisical_project_id {{ '}}' }} --env={{ '{{' }} infisical_env {{ '}}' }} --path={{ '{{' }} infisical_path {{ '}}' }} -- bash -c '
          keys="${OPS_AUTHORIZED_KEYS:-}"
          dest=/root/.ssh/authorized_keys.weown-ops
          umask 077; tmp=$(mktemp)
          # Keep only non-blank lines. An unset, empty, or all-whitespace value
          # yields an empty file here; treat that the same as "unset" and leave
          # the destination untouched, so a blank OPS_AUTHORIZED_KEYS can never
          # wipe authorized_keys.weown-ops and revoke all team SSH access.
          printf "%s\n" "$keys" | grep -vE "^[[:space:]]*$" > "$tmp" || true
          if [ ! -s "$tmp" ]; then
            rm -f "$tmp"
            echo "WARN: OPS_AUTHORIZED_KEYS is unset or has no non-blank lines; leaving team keys unchanged."
            exit 0
          fi
          if cmp -s "$tmp" "$dest" 2>/dev/null; then
            rm -f "$tmp"; echo "unchanged"
          else
            install -m 600 -o root -g root "$tmp" "$dest"; rm -f "$tmp"
            echo "synced $(grep -c . "$dest") team key(s)"
          fi
        '
      args:
        executable: /bin/bash
      register: ops_keys_sync
      changed_when: "'synced' in ops_keys_sync.stdout"

    - name: Fetch MINIMUS_TOKEN from Infisical (for reg.mini.dev login)
      # caddy:2 and the AnythingLLM image live on the Minimus registry
      # (reg.mini.dev), which requires authentication even for the "public"
      # caddy image. Without this, "Pull caddy image" below fails with
      # 401 Unauthorized on fresh droplets. The token is used as the
      # password; username is "minimus".
      ansible.builtin.shell: |
        set -euo pipefail
        # shellcheck disable=SC1091
        source {{ '{{' }} app_dir {{ '}}' }}/.infisical-auth.env
        export INFISICAL_UNIVERSAL_AUTH_CLIENT_ID="$INFISICAL_CLIENT_ID"
        export INFISICAL_UNIVERSAL_AUTH_CLIENT_SECRET="$INFISICAL_CLIENT_SECRET"
        export INFISICAL_TOKEN="$(infisical login --method=universal-auth --plain --silent)"
        infisical run \
          --projectId={{ '{{' }} infisical_project_id {{ '}}' }} \
          --env={{ '{{' }} infisical_env {{ '}}' }} --path={{ '{{' }} infisical_path {{ '}}' }} \
          -- bash -c 'printf "%s" "$MINIMUS_TOKEN"'
      args:
        executable: /bin/bash
      register: minimus_token
      changed_when: false
      failed_when: minimus_token.stdout | length == 0
      no_log: true

    - name: Log in to reg.mini.dev (Minimus registry)
      # Uses CLI docker login instead of community.docker.docker_login
      # to avoid requiring the Docker SDK for Python on the target host.
      ansible.builtin.shell: |
        printf '%s' '{{ '{{' }} minimus_token.stdout {{ '}}' }}' | docker login reg.mini.dev -u minimus --password-stdin
      args:
        executable: /bin/bash
      changed_when: false
      no_log: true

    - name: Pull caddy image
      # caddy is a static public ref. The AnythingLLM image is pulled by the
      # compose-up step below — its ref comes from Infisical (ANYTHINGLLM_IMAGE),
      # so it must be pulled under `infisical run`, not here.
      # docker_image_pull is CLI-based (no python3-docker SDK needed on the droplet).
      community.docker.docker_image_pull:
        name: "{{ '{{' }} caddy_image {{ '}}' }}"
      register: image_pull
      retries: 3
      delay: 5
      until: image_pull is succeeded

    - name: Ensure caddy log dir is writable (hardened caddy runs non-root)
      # caddy:2 (Minimus-hardened) runs as a non-root user and writes access
      # logs to the /var/log/caddy host bind mount. Without a writable dir it
      # crash-loops with "permission denied". 0777 is acceptable for a
      # single-tenant log dir; otel-agent also reads these files.
      ansible.builtin.file:
        path: /var/log/caddy
        state: directory
        owner: root
        group: root
        mode: "0777"

    # ─── ADR-006: Container-readable auth file ────────────────────────────
    # The host auth file is 0600 root, but the container may run as non-root.
    # Create a container-readable copy (0644) that the compose bind-mounts
    # read-only. Host-side privacy is preserved by the 0700 app directory.
    # This is the "one fiddly bit" from ADR-006.
    - name: Create container-readable Infisical auth file (ADR-006)
      ansible.builtin.copy:
        src: "{{ '{{' }} app_dir {{ '}}' }}/.infisical-auth.env"
        dest: "{{ '{{' }} app_dir {{ '}}' }}/.infisical-auth.env.container"
        owner: root
        group: root
        mode: "0644"
        remote_src: true
      notify: Reconcile docker compose stack

    - name: Ensure compose stack is running (idempotent — `up -d` is a no-op if nothing changed)
      # ADR-006: NO host-side `infisical run` wrapper — container fetches secrets
      # via its own entrypoint. A plain `docker compose up -d` starts the stack;
      # each container authenticates to Infisical in-process using the bind-mounted
      # auth file. This enables bounce-to-refresh: `docker restart` re-fetches secrets.
      #
      # Note: ANYTHINGLLM_IMAGE is fetched from Infisical and exported before docker compose up
      # because the compose file uses ${ANYTHINGLLM_IMAGE} for the image reference.
      ansible.builtin.shell: |
        set -euo pipefail
        source {{ '{{' }} app_dir {{ '}}' }}/.infisical-auth.env
        export INFISICAL_UNIVERSAL_AUTH_CLIENT_ID="$INFISICAL_CLIENT_ID"
        export INFISICAL_UNIVERSAL_AUTH_CLIENT_SECRET="$INFISICAL_CLIENT_SECRET"
        infisical login --method=universal-auth --silent
        export ANYTHINGLLM_IMAGE=$(infisical secrets get ANYTHINGLLM_IMAGE \
          --projectId={{ '{{' }} infisical_project_id {{ '}}' }} \
          --env={{ '{{' }} infisical_env {{ '}}' }} --path={{ '{{' }} infisical_path {{ '}}' }} \
          --plain 2>/dev/null || echo "")
        if [[ -z "$ANYTHINGLLM_IMAGE" ]]; then
          echo "ERROR: ANYTHINGLLM_IMAGE not found in Infisical"
          exit 1
        fi
        cd {{ '{{' }} app_dir {{ '}}' }}
        docker compose up -d --remove-orphans
      args:
        executable: /bin/bash
      register: compose_up
      changed_when: "'Started' in compose_up.stderr or 'Created' in compose_up.stderr or 'Recreated' in compose_up.stderr"

    - name: Wait for AnythingLLM health
      ansible.builtin.uri:
        url: http://127.0.0.1:3001/api/ping
        status_code: 200
      register: health_probe
      retries: 20
      delay: 5
      until: health_probe.status == 200

    # ─── DO droplet tagging ──────────────────────────────────────────────
    # After a successful deploy, update droplet tags to reflect actual state:
    # - skinny-backup tag (we just configured the cron)
    # - commit-<sha> tag (which git commit produced this deployment)
    # See docs/INFRA_BOOTSTRAP_PATTERN.md "DO tag taxonomy" for the full scheme.
    # Tags are mutated via the shared scripts/tag-droplet.sh helper; ansible
    # runs it locally via delegate_to.

    - name: Update DO droplet tags (skinny-backup + commit-<sha>)
      ansible.builtin.shell: |
        set -euo pipefail
        scripts/tag-droplet.sh "{{ '{{' }} droplet_name {{ '}}' }}" \
          replace-prefix commit- "commit-{{ '{{' }} git_commit_short {{ '}}' }}" \
          add skinny-backup
      args:
        executable: /bin/bash
        # Walk up to the WeOwn repo root so `scripts/tag-droplet.sh` resolves.
        # Layout: <repo-root>/anythingllm-docker/sites/<name>/ansible/deploy.yml
        #   playbook_dir         = …/anythingllm-docker/sites/<name>/ansible
        #   dirname × 4          = <repo-root>
        chdir: "{{ '{{' }} playbook_dir | dirname | dirname | dirname | dirname {{ '}}' }}"
      delegate_to: localhost
      become: false
      changed_when: false
      failed_when: false   # Tagging failure must not block the deploy

    - name: Report success
      ansible.builtin.debug:
        msg: >-
          {{ project_name }} app layer deployed (commit
          {{ '{{' }} git_commit_short {{ '}}' }}).
          URL: https://{{ domain }}/

  handlers:
    - name: Reconcile docker compose stack
      # ADR-006: NO host-side `infisical run` wrapper — container fetches secrets
      # via its own entrypoint. Force-recreate ensures containers pick up any
      # changes to the compose file or bind-mounted auth file.
      #
      # Note: ANYTHINGLLM_IMAGE must be fetched from Infisical before docker compose up
      # because the compose file uses ${ANYTHINGLLM_IMAGE:?} for the image reference.
      # This handler mirrors the main compose-up task.
      ansible.builtin.shell: |
        set -euo pipefail
        source {{ '{{' }} app_dir {{ '}}' }}/.infisical-auth.env
        export INFISICAL_UNIVERSAL_AUTH_CLIENT_ID="$INFISICAL_CLIENT_ID"
        export INFISICAL_UNIVERSAL_AUTH_CLIENT_SECRET="$INFISICAL_CLIENT_SECRET"
        infisical login --method=universal-auth --silent
        export ANYTHINGLLM_IMAGE=$(infisical secrets get ANYTHINGLLM_IMAGE \
          --projectId={{ '{{' }} infisical_project_id {{ '}}' }} \
          --env={{ '{{' }} infisical_env {{ '}}' }} --path={{ '{{' }} infisical_path {{ '}}' }} \
          --plain 2>/dev/null || echo "")
        if [[ -z "$ANYTHINGLLM_IMAGE" ]]; then
          echo "ERROR: ANYTHINGLLM_IMAGE not found in Infisical"
          exit 1
        fi
        cd {{ '{{' }} app_dir {{ '}}' }}
        docker compose up -d --force-recreate --remove-orphans
      args:
        executable: /bin/bash
      changed_when: false

    - name: Reload sshd
      # `sshd -t` validates the FULL config (incl. the drop-in) before reload;
      # if it fails we do NOT reload, so the running (working) sshd is untouched.
      ansible.builtin.shell: |
        set -euo pipefail
        sshd -t
        systemctl reload ssh 2>/dev/null || systemctl reload sshd
      args:
        executable: /bin/bash
      changed_when: false
