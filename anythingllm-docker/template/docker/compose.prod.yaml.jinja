# {{ project_name }} - Docker Compose (ADR-006: In-Container Infisical Injection)
# Secrets are fetched IN-PROCESS by the container at startup via `infisical run` entrypoint.
# A `docker restart` re-fetches secrets (bounce-to-refresh). No secrets in environment: block.
# No secrets should be stored in this file or in .env files on disk.
#
# Required Infisical secrets:
#   ANYTHINGLLM_IMAGE, OPENROUTER_API_KEY, JWT_SECRET, ADMIN_EMAIL
# Optional Infisical secrets:
#   OPENROUTER_MODEL_PREF, OPENROUTER_TIMEOUT_MS, EMBEDDING_ENGINE,
#   EMBEDDING_MODEL_PREF, EMBEDDING_BASE_PATH, AUTH_TOKEN, AUTH_MODE,
#   ALLOW_MULTI_WORKSPACE, COMMUNITY_HUB_BUNDLE_DOWNLOADS_ENABLED

services:
  anythingllm:
    # Image ref is injected from Infisical (ANYTHINGLLM_IMAGE) so the private
    # registry namespace stays out of this public repo and each site pins its
    # own version. Set ANYTHINGLLM_IMAGE in the site's Infisical project, e.g.
    # reg.mini.dev/<namespace>/anythingllm:v1.12.1
    image: "${ANYTHINGLLM_IMAGE:?ANYTHINGLLM_IMAGE not injected - set it in Infisical}"
    restart: unless-stopped
    # ADR-006: wrapper script authenticates to Infisical and execs original entrypoint
    entrypoint: ["/opt/{{ project_name | replace('-', '_') }}/entrypoint-infisical.sh"]
    # Chain the image's real entrypoint (docker-entrypoint.sh) which starts BOTH
    # the server (node /app/server/index.js) AND the collector (node /app/collector/index.js).
    # Overriding with just "node server/index.js" silently kills the collector,
    # breaking document upload/embedding.
    command: ["/bin/bash", "/usr/local/bin/docker-entrypoint.sh"]
    ports:
      # Loopback-only: lets the deploy health probe and the runbook validation
      # tunnel (ssh -L 3001:127.0.0.1:3001) reach AnythingLLM before DNS cutover.
      # NOT internet-exposed (loopback bind + firewall); caddy proxies public
      # traffic to anythingllm:3001 over the internal Docker network.
      - "127.0.0.1:3001:3001"
    environment:
      # Server configuration (non-secret)
      SERVER_PORT: "3001"
      STORAGE_DIR: "/app/server/storage"
      # LLM Configuration
      LLM_PROVIDER: "{{ llm_provider }}"
      OPENROUTER_MODEL_PREF: "{{ openrouter_model_pref }}"
      OPENROUTER_TIMEOUT_MS: "3000"
      # Vector Database (embedded LanceDB)
      VECTOR_DB: "{{ vector_db }}"
      # Embedding Configuration
      EMBEDDING_ENGINE: "native"
      EMBEDDING_MODEL_PREF: ""
      EMBEDDING_BASE_PATH: ""
      # Security settings
      DISABLE_TELEMETRY: "true"
      # Community Hub
      COMMUNITY_HUB_BUNDLE_DOWNLOADS_ENABLED: "1"
      # Auth / multi-user (optional)
      AUTH_TOKEN: ""
      AUTH_MODE: ""
      ALLOW_MULTI_WORKSPACE: "true"
      # Secrets (OPENROUTER_API_KEY, JWT_SECRET, ADMIN_EMAIL) are fetched by
      # infisical run entrypoint, NOT listed here. This prevents them from
      # appearing in `docker inspect` and enables bounce-to-refresh.
    volumes:
      - anythingllm_storage:/app/server/storage
      # ADR-006: bind-mount Infisical CLI + auth file + wrapper script (read-only)
      - /usr/bin/infisical:/usr/bin/infisical:ro
      - /opt/{{ project_name | replace('-', '_') }}/.infisical-auth.env.container:/.infisical-auth.env:ro
      - /opt/{{ project_name | replace('-', '_') }}/entrypoint-infisical.sh:/opt/{{ project_name | replace('-', '_') }}/entrypoint-infisical.sh:ro
    networks:
      - anythingllmnet
    healthcheck:
      test: ["CMD-SHELL", "curl -f http://localhost:3001/api/ping || exit 1"]
      start_period: 60s
      interval: 30s
      timeout: 10s
      retries: 5
    deploy:
      resources:
        limits:
          memory: 2G
        reservations:
          memory: 1G

  caddy:
    image: {{ caddy_image }}
    restart: unless-stopped
    depends_on:
      - anythingllm
    environment:
      DOMAIN: {{ domain }}
    ports:
      - "80:80"
      - "443:443"
      - "443:443/udp"
    volumes:
      - ./Caddyfile:/etc/caddy/Caddyfile:ro
      - caddy_data:/data
      - caddy_config:/config
      # Bind-mount access logs to host so otel-agent's filelog/caddy receiver
      # (mounts /var/log host-side) can read them, and so logs survive container
      # recreation. The Caddyfile in cloud-init writes to /var/log/caddy/.
      - /var/log/caddy:/var/log/caddy
    networks:
      - anythingllmnet
    deploy:
      resources:
        limits:
          memory: 256M
        reservations:
          memory: 128M

volumes:
  anythingllm_storage:
    name: {{ project_name | replace('-', '_') }}_storage
  caddy_data:
    name: {{ project_name | replace('-', '_') }}_caddy_data
  caddy_config:
    name: {{ project_name | replace('-', '_') }}_caddy_config

networks:
  anythingllmnet:
    name: {{ project_name | replace('-', '_') }}_net
    driver: bridge
