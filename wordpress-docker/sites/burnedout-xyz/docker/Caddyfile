# Apex domain style: burnedout.xyz is primary
{$DOMAIN} {
    root * /var/www/html
    php_fastcgi wordpress:9000
    file_server
    encode zstd gzip

    # Block direct access to .user.ini (Wordfence WAF config)
    @userini path /.user.ini
    respond @userini 403

    # Security headers
    header {
        X-Content-Type-Options nosniff
        X-Frame-Options SAMEORIGIN
        X-XSS-Protection "1; mode=block"
        Referrer-Policy strict-origin-when-cross-origin
        -Server
    }

    # Block access to sensitive files
    @blocked path *.sql *.log *.bak *.backup *.swp *.old *.orig *.tmp /wp-config.php
    respond @blocked 404

    # Block PHP execution in uploads
    @phpuploads path /wp-content/uploads/*.php
    respond @phpuploads 403
}

www.{$DOMAIN} {
    redir https://{$DOMAIN}{uri} permanent
}
