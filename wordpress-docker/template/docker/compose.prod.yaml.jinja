# {{ project_name }} - Docker Compose (Infisical Runtime Injection)
# Secrets are injected at container startup via `infisical run`
# No secrets should be stored in this file or in .env files on disk
#
# Required Infisical secrets:
#   MYSQL_DATABASE, MYSQL_USER, MYSQL_PASSWORD, MYSQL_ROOT_PASSWORD, DOMAIN
# Optional Infisical secrets:
#   MINIMUS_TOKEN (for reg.mini.dev image pulls)
#   SPACES_ACCESS_KEY, SPACES_SECRET_KEY (for remote backups)

services:
  db:
    # Pinned to a specific MariaDB version — update together with
    # var.mariadb_version in terraform/variables.tf when bumping.
    image: mariadb:{{ mariadb_version }}
    restart: unless-stopped
    environment:
      MYSQL_DATABASE: ${MYSQL_DATABASE}
      MYSQL_USER: ${MYSQL_USER}
      MYSQL_PASSWORD: ${MYSQL_PASSWORD}
      MYSQL_ROOT_PASSWORD: ${MYSQL_ROOT_PASSWORD}
    volumes:
      - db_data:/var/lib/mysql
    networks:
      - wpnet
    healthcheck:
      test: ["CMD", "healthcheck.sh", "--connect", "--innodb_initialized"]
      start_period: 30s
      interval: 10s
      timeout: 5s
      retries: 3
    deploy:
      resources:
        limits:
          memory: 1G
        reservations:
          memory: 512M

  wordpress:
    # Pinned to a specific WordPress image — update together with
    # var.wp_image in terraform/variables.tf when bumping.
    image: {{ wp_image }}
    restart: unless-stopped
    depends_on:
      db:
        condition: service_healthy
    environment:
      WORDPRESS_DB_HOST: db:3306
      WORDPRESS_DB_NAME: ${MYSQL_DATABASE}
      WORDPRESS_DB_USER: ${MYSQL_USER}
      WORDPRESS_DB_PASSWORD: ${MYSQL_PASSWORD}
      WORDPRESS_CONFIG_EXTRA: |
{%- if domain_style == 'www' %}
        define('WP_HOME', 'https://www.${DOMAIN}');
        define('WP_SITEURL', 'https://www.${DOMAIN}');
{%- else %}
        define('WP_HOME', 'https://${DOMAIN}');
        define('WP_SITEURL', 'https://${DOMAIN}');
{%- endif %}
        if (isset($$_SERVER['HTTP_X_FORWARDED_PROTO']) && $$_SERVER['HTTP_X_FORWARDED_PROTO'] === 'https') {
          $$_SERVER['HTTPS'] = 'on';
        }
    volumes:
      - wp_data:/var/www/html
{%- if enable_wordfence_waf %}
      - ./wordfence-waf/.user.ini:/var/www/html/.user.ini:ro
{%- endif %}
    networks:
      - wpnet
    healthcheck:
      test: ["CMD-SHELL", "curl -f http://localhost/ || exit 1"]
      start_period: 60s
      interval: 30s
      timeout: 10s
      retries: 5
    deploy:
      resources:
        limits:
          memory: 1G
        reservations:
          memory: 512M

  caddy:
    image: {{ caddy_image }}
    restart: unless-stopped
    depends_on:
      - wordpress
    environment:
      DOMAIN: ${DOMAIN}
    ports:
      - "80:80"
      - "443:443"
      - "443:443/udp"
    volumes:
      - ./Caddyfile:/etc/caddy/Caddyfile:ro
      - wp_data:/var/www/html:ro
      - caddy_data:/data
      - caddy_config:/config
      # Bind-mount access logs to host so otel-agent's filelog/caddy receiver
      # (mounts /var/log host-side) can read them, and so logs survive container
      # recreation. The Caddyfile writes to /var/log/caddy/.
      - /var/log/caddy:/var/log/caddy
    networks:
      - wpnet
    deploy:
      resources:
        limits:
          memory: 256M
        reservations:
          memory: 128M

volumes:
  db_data:
    name: {{ project_name | replace('-', '_') }}_db_data
  wp_data:
    name: {{ project_name | replace('-', '_') }}_wp_data
  caddy_data:
    name: {{ project_name | replace('-', '_') }}_caddy_data
  caddy_config:
    name: {{ project_name | replace('-', '_') }}_caddy_config

networks:
  wpnet:
    name: {{ project_name | replace('-', '_') }}_wpnet
    driver: bridge
