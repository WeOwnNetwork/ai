# {{ project_name }} - Docker Compose (ADR-006: In-Container Infisical Injection)
# Secrets are fetched IN-PROCESS by containers at startup via `infisical run` entrypoint.
# A `docker restart` re-fetches secrets (bounce-to-refresh). No secrets in environment: blocks.
# No secrets should be stored in this file or in .env files on disk.
#
# Required Infisical secrets (names must match each app's expected env var names):
#   MariaDB:   MYSQL_DATABASE, MYSQL_USER, MYSQL_PASSWORD, MYSQL_ROOT_PASSWORD
#   WordPress: WORDPRESS_DB_NAME, WORDPRESS_DB_USER, WORDPRESS_DB_PASSWORD, DOMAIN
#
# Note: WORDPRESS_DB_NAME, WORDPRESS_DB_USER, WORDPRESS_DB_PASSWORD hold the same values
# as MYSQL_DATABASE, MYSQL_USER, MYSQL_PASSWORD respectively, but are stored as separate
# Infisical secrets so each app sees the env var names it expects.
#
# Optional Infisical secrets:
#   MINIMUS_TOKEN (for reg.mini.dev image pulls)
#   SPACES_ACCESS_KEY, SPACES_SECRET_KEY (for remote backups)

services:
  db:
    # Pinned to a specific MariaDB version — update together with
    # var.mariadb_version in terraform/variables.tf when bumping.
    image: mariadb:{{ mariadb_version }}
    restart: unless-stopped
    # ADR-006: wrapper script authenticates to Infisical and execs original entrypoint
    entrypoint: ["/opt/{{ project_name | replace('-', '_') }}/entrypoint-infisical.sh"]
    command: ["docker-entrypoint.sh", "mariadbd"]
    # Secrets (MYSQL_DATABASE, MYSQL_USER, MYSQL_PASSWORD, MYSQL_ROOT_PASSWORD)
    # fetched by entrypoint, NOT listed here.
    volumes:
      - db_data:/var/lib/mysql
      # ADR-006: bind-mount Infisical CLI + auth file + wrapper script (read-only)
      - /usr/bin/infisical:/usr/bin/infisical:ro
      - /opt/{{ project_name | replace('-', '_') }}/.infisical-auth.env.container:/.infisical-auth.env:ro
      - /opt/{{ project_name | replace('-', '_') }}/entrypoint-infisical.sh:/opt/{{ project_name | replace('-', '_') }}/entrypoint-infisical.sh:ro
    networks:
      - wpnet
    healthcheck:
      test: ["CMD", "healthcheck.sh", "--connect", "--innodb_initialized"]
      start_period: 30s
      interval: 10s
      timeout: 5s
      retries: 3
    deploy:
      resources:
        limits:
          memory: 1G
        reservations:
          memory: 512M

  wordpress:
    # Pinned to a specific WordPress image — update together with
    # var.wp_image in terraform/variables.tf when bumping.
    image: {{ wp_image }}
    restart: unless-stopped
    depends_on:
      db:
        condition: service_healthy
    # ADR-006: wrapper script authenticates to Infisical and execs original entrypoint
    entrypoint: ["/opt/{{ project_name | replace('-', '_') }}/entrypoint-infisical.sh"]
    command: ["docker-entrypoint.sh", "apache2-foreground"]
    environment:
      # Non-secret config only; secrets fetched by entrypoint
      WORDPRESS_DB_HOST: db:3306
      WORDPRESS_CONFIG_EXTRA: |
{%- if domain_style == 'www' %}
        define('WP_HOME', 'https://www.' . getenv('DOMAIN'));
        define('WP_SITEURL', 'https://www.' . getenv('DOMAIN'));
{%- else %}
        define('WP_HOME', 'https://' . getenv('DOMAIN'));
        define('WP_SITEURL', 'https://' . getenv('DOMAIN'));
{%- endif %}
        if (isset($$_SERVER['HTTP_X_FORWARDED_PROTO']) && $$_SERVER['HTTP_X_FORWARDED_PROTO'] === 'https') {
          $$_SERVER['HTTPS'] = 'on';
        }
      # Secrets (WORDPRESS_DB_NAME, WORDPRESS_DB_USER, WORDPRESS_DB_PASSWORD, DOMAIN)
      # fetched by entrypoint, NOT listed here.
    volumes:
      - wp_data:/var/www/html
{%- if enable_wordfence_waf %}
      - ./wordfence-waf/.user.ini:/var/www/html/.user.ini:ro
{%- endif %}
      # ADR-006: bind-mount Infisical CLI + auth file + wrapper script (read-only)
      - /usr/bin/infisical:/usr/bin/infisical:ro
      - /opt/{{ project_name | replace('-', '_') }}/.infisical-auth.env.container:/.infisical-auth.env:ro
      - /opt/{{ project_name | replace('-', '_') }}/entrypoint-infisical.sh:/opt/{{ project_name | replace('-', '_') }}/entrypoint-infisical.sh:ro
    networks:
      - wpnet
    healthcheck:
      test: ["CMD-SHELL", "curl -f http://localhost/ || exit 1"]
      start_period: 60s
      interval: 30s
      timeout: 10s
      retries: 5
    deploy:
      resources:
        limits:
          memory: 1G
        reservations:
          memory: 512M

  caddy:
    image: {{ caddy_image }}
    restart: unless-stopped
    depends_on:
      - wordpress
    # ADR-006: wrapper script authenticates to Infisical and execs original entrypoint
    entrypoint: ["/opt/{{ project_name | replace('-', '_') }}/entrypoint-infisical.sh"]
    command: ["caddy", "run", "--config", "/etc/caddy/Caddyfile", "--adapter", "caddyfile"]
    # DOMAIN fetched by entrypoint, NOT listed here.
    ports:
      - "80:80"
      - "443:443"
      - "443:443/udp"
    volumes:
      - ./Caddyfile:/etc/caddy/Caddyfile:ro
      - wp_data:/var/www/html:ro
      - caddy_data:/data
      - caddy_config:/config
      # Bind-mount access logs to host so otel-agent's filelog/caddy receiver
      # (mounts /var/log host-side) can read them, and so logs survive container
      # recreation. The Caddyfile writes to /var/log/caddy/.
      - /var/log/caddy:/var/log/caddy
      # ADR-006: bind-mount Infisical CLI + auth file + wrapper script (read-only)
      - /usr/bin/infisical:/usr/bin/infisical:ro
      - /opt/{{ project_name | replace('-', '_') }}/.infisical-auth.env.container:/.infisical-auth.env:ro
      - /opt/{{ project_name | replace('-', '_') }}/entrypoint-infisical.sh:/opt/{{ project_name | replace('-', '_') }}/entrypoint-infisical.sh:ro
    networks:
      - wpnet
    deploy:
      resources:
        limits:
          memory: 256M
        reservations:
          memory: 128M

volumes:
  db_data:
    name: {{ project_name | replace('-', '_') }}_db_data
  wp_data:
    name: {{ project_name | replace('-', '_') }}_wp_data
  caddy_data:
    name: {{ project_name | replace('-', '_') }}_caddy_data
  caddy_config:
    name: {{ project_name | replace('-', '_') }}_caddy_config

networks:
  wpnet:
    name: {{ project_name | replace('-', '_') }}_wpnet
    driver: bridge
