services:
  db:
    image: mariadb:{{ mariadb_version }}
    restart: unless-stopped
    environment:
      MYSQL_DATABASE: ${MYSQL_DATABASE}
      MYSQL_USER: ${MYSQL_USER}
      MYSQL_PASSWORD: ${MYSQL_PASSWORD}
      MYSQL_ROOT_PASSWORD: ${MYSQL_ROOT_PASSWORD}
    volumes:
      - db_data:/var/lib/mysql
    networks:
      - wpnet
    healthcheck:
      test: ["CMD", "healthcheck.sh", "--connect", "--innodb_initialized"]
      start_period: 30s
      interval: 10s
      timeout: 5s
      retries: 3

  wordpress:
    image: ${WP_IMAGE}
    restart: unless-stopped
    depends_on:
      db:
        condition: service_healthy
    environment:
      WORDPRESS_DB_HOST: db:3306
      WORDPRESS_DB_NAME: ${MYSQL_DATABASE}
      WORDPRESS_DB_USER: ${MYSQL_USER}
      WORDPRESS_DB_PASSWORD: ${MYSQL_PASSWORD}
      WORDPRESS_CONFIG_EXTRA: |
{%- if domain_style == 'www' %}
        define('WP_HOME', 'https://www.${DOMAIN}');
        define('WP_SITEURL', 'https://www.${DOMAIN}');
{%- else %}
        define('WP_HOME', 'https://${DOMAIN}');
        define('WP_SITEURL', 'https://${DOMAIN}');
{%- endif %}
        if (isset($$_SERVER['HTTP_X_FORWARDED_PROTO']) && $$_SERVER['HTTP_X_FORWARDED_PROTO'] === 'https') {
          $$_SERVER['HTTPS'] = 'on';
        }
    volumes:
      - wp_data:/var/www/html
      - ./wordfence-waf/.user.ini:/var/www/html/.user.ini:ro
    networks:
      - wpnet

  caddy:
    image: ${CADDY_IMAGE}
    restart: unless-stopped
    depends_on:
      - wordpress
    environment:
      DOMAIN: ${DOMAIN}
    ports:
      - "80:80"
      - "443:443"
      - "443:443/udp"
    volumes:
      - ./Caddyfile:/etc/caddy/Caddyfile:ro
      - wp_data:/var/www/html:ro
      - caddy_data:/data
      - caddy_config:/config
    networks:
      - wpnet

volumes:
  db_data:
    name: {{ project_name | replace('-', '_') }}_db_data
  wp_data:
    name: {{ project_name | replace('-', '_') }}_wp_data
  caddy_data:
    name: {{ project_name | replace('-', '_') }}_caddy_data
  caddy_config:
    name: {{ project_name | replace('-', '_') }}_caddy_config

networks:
  wpnet:
    name: {{ project_name | replace('-', '_') }}_wpnet
