# {{ project_name }} — Production secrets are managed by Infisical.
#
# This file is intentionally empty. Do NOT create a .env.prod with real values.
#
# Store the following secrets in Infisical:
#   Project : {{ infisical_project_id }}
#   Env     : {{ infisical_environment }}
#
#   MYSQL_DATABASE       = wordpress
#   MYSQL_USER           = wordpress
#   MYSQL_PASSWORD       = <strong-random-password>
#   MYSQL_ROOT_PASSWORD  = <strong-random-root-password>
#   DOMAIN               = {{ domain }}
#   WP_IMAGE             = {{ wp_image }}
#   CADDY_IMAGE          = {{ caddy_image }}
#
# The Terraform cloud-init and deploy scripts inject these at runtime via:
#   infisical run --projectId={{ infisical_project_id }} --env={{ infisical_environment }} -- docker compose up -d
#
# See README.md for setup instructions.
