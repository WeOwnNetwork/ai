; WordPress PHP configuration overrides
; Applied via PHP-FPM per-directory .user.ini (read from web root)
; Managed by IaC — do not edit on server. Changes here deploy via Ansible.

; Upload and memory limits
upload_max_filesize = {{ php_upload_max_filesize }}
post_max_size = {{ php_post_max_size }}
memory_limit = {{ php_memory_limit }}
max_execution_time = {{ php_max_execution_time }}
{%- if enable_wordfence_waf %}

; Wordfence WAF Configuration
; IMPORTANT: Apache/Nginx use .htaccess or php.ini for this config.
; Caddy does NOT support those, so we use .user.ini instead.
; Direct web access to this file is blocked in Caddyfile.
; See: https://www.wordfence.com/help/firewall/optimizing-the-firewall/

auto_prepend_file = '/var/www/html/wordfence-waf.php'
{%- endif %}
