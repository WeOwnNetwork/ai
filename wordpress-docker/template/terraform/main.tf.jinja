# {{ project_name }} - Main Infrastructure
# Managed by OpenTofu

resource "digitalocean_droplet" "web" {
  name       = "{{ project_name }}"
  image      = var.droplet_image
  size       = var.droplet_size
  region     = var.region
  monitoring = true
{%- if not enable_skinny_backups %}
  backups    = true
{%- else %}
  backups    = false  # Using skinny volume backups instead
{%- endif %}
  ssh_keys   = [var.ssh_key_fingerprint]

  # Cloud-init handles ONLY first-boot bootstrap (Docker, Infisical CLI,
  # .infisical-auth.env, bootstrap-secret rotation). App-layer state
  # (compose.yaml, Caddyfile, backup.sh, cron) is managed by ansible/deploy.yml.
  user_data = templatefile("${path.module}/templates/cloud-init.yaml", {
    project_name        = "{{ project_name | replace('-', '_') }}"
    domain              = var.domain
    domain_style        = var.domain_style
    minimus_token       = var.minimus_token
    wp_image            = var.wp_image
    caddy_image         = var.caddy_image
    mariadb_version     = var.mariadb_version
{%- if enable_infisical %}
    infisical_client_id     = var.infisical_client_id
    infisical_client_secret = var.infisical_client_secret
    infisical_project_id    = var.infisical_project_id
    infisical_environment   = var.infisical_environment
  })

  # Base tags. Feature tags + commit tag are added at runtime by:
  #   - scripts/tag-droplet.sh (helper, invoked by ansible deploy + bootstrap scripts)
  #   - ansible/deploy.yml (adds skinny-backup + commit-<sha>)
  # See docs/INFRA_BOOTSTRAP_PATTERN.md "DO tag taxonomy" for the full scheme.
  # `ignore_changes = [tags]` prevents tofu apply from reverting runtime-added
  # tags on subsequent runs.
  tags = ["{{ project_name }}", "wordpress", "weown-ai"]

  lifecycle {
    ignore_changes = [user_data, tags]
  }
}

resource "digitalocean_reserved_ip" "web" {
  region = var.region
}

resource "digitalocean_reserved_ip_assignment" "web" {
  ip_address = digitalocean_reserved_ip.web.ip_address
  droplet_id = digitalocean_droplet.web.id
}

#trivy:ignore:AVD-DIG-0001  # Public web server: HTTP/HTTPS inbound from internet is required by design
#trivy:ignore:AVD-DIG-0003  # Public web server: unrestricted outbound required for OS updates, ACME, APIs
resource "digitalocean_firewall" "web" {
  name        = "{{ project_name }}-fw"
  droplet_ids = [digitalocean_droplet.web.id]

  # SSH
  inbound_rule {
    protocol         = "tcp"
    port_range       = "22"
    source_addresses = ["0.0.0.0/0", "::/0"]
  }

  # HTTP (for ACME challenges and redirects)
  inbound_rule {
    protocol         = "tcp"
    port_range       = "80"
    source_addresses = ["0.0.0.0/0", "::/0"]
  }

  # HTTPS
  inbound_rule {
    protocol         = "tcp"
    port_range       = "443"
    source_addresses = ["0.0.0.0/0", "::/0"]
  }

  # HTTPS/QUIC (HTTP/3)
  inbound_rule {
    protocol         = "udp"
    port_range       = "443"
    source_addresses = ["0.0.0.0/0", "::/0"]
  }

  # All outbound TCP
  outbound_rule {
    protocol              = "tcp"
    port_range            = "1-65535"
    destination_addresses = ["0.0.0.0/0", "::/0"]
  }

  # All outbound UDP
  outbound_rule {
    protocol              = "udp"
    port_range            = "1-65535"
    destination_addresses = ["0.0.0.0/0", "::/0"]
  }

  # ICMP for ping/diagnostics
  outbound_rule {
    protocol              = "icmp"
    destination_addresses = ["0.0.0.0/0", "::/0"]
  }
}

