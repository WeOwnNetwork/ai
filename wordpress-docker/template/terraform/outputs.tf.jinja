# {{ project_name }} - Terraform Outputs
# Managed by OpenTofu

output "droplet_ip" {
  description = "Droplet IPv4 address (reserved IP)"
  value       = digitalocean_reserved_ip.web.ip_address
}

output "droplet_id" {
  description = "Droplet ID"
  value       = digitalocean_droplet.web.id
}

output "domain" {
  description = "Primary domain"
  value       = var.domain
}

output "site_url" {
  description = "Production site URL"
{%- if domain_style == 'www' %}
  value       = "https://www.{{ domain }}"
{%- else %}
  value       = "https://{{ domain }}"
{%- endif %}
}

output "infisical_project" {
  description = "Infisical project ID for secrets management"
  value       = var.infisical_project_id
}
