#!/usr/bin/env bash
# {{ project_name }} - Skinny Backup Script
# Backs up SearXNG config, Valkey data, and Caddy TLS certificates.
#
# Usage:
#   On the droplet (within infisical run):
#     infisical run --projectId=... --env=... -- ./backup.sh
#
# Assumes: called via `infisical run` so SPACES_ACCESS_KEY, SPACES_SECRET_KEY
# are in environment (if remote storage is configured).
set -euo pipefail

APP_DIR="/opt/{{ project_name | replace('-', '_') }}"
BACKUP_DIR="$APP_DIR/backups"
TIMESTAMP=$(date +%Y%m%d_%H%M%S)
BACKUP_NAME="{{ project_name }}_backup_$TIMESTAMP"
WORK_DIR="$BACKUP_DIR/$BACKUP_NAME"
PROJECT_NAME="{{ project_name | replace('-', '_') }}"

REMOTE_STORAGE="{{ backup_remote_storage }}"
SPACES_BUCKET="{{ backup_do_spaces_bucket }}"
SPACES_REGION="{{ backup_do_spaces_region }}"

mkdir -p "$WORK_DIR"
echo "==> Creating backup: $BACKUP_NAME"

# --- Volume backups using ephemeral alpine containers ---
echo "==> Backing up SearXNG config volume..."
docker run --rm \
  -v "${PROJECT_NAME}_searxng_config:/data:ro" \
  -v "$WORK_DIR:/backup" \
  alpine:3.19 \
  tar czf /backup/searxng_config.tar.gz -C /data .

echo "==> Backing up Valkey data volume..."
docker run --rm \
  -v "${PROJECT_NAME}_valkey_data:/data:ro" \
  -v "$WORK_DIR:/backup" \
  alpine:3.19 \
  tar czf /backup/valkey_data.tar.gz -C /data .

echo "==> Backing up Caddy data volume..."
docker run --rm \
  -v "${PROJECT_NAME}_caddy_data:/data:ro" \
  -v "$WORK_DIR:/backup" \
  alpine:3.19 \
  tar czf /backup/caddy_data.tar.gz -C /data .

echo "==> Backing up Caddy config volume..."
docker run --rm \
  -v "${PROJECT_NAME}_caddy_config:/data:ro" \
  -v "$WORK_DIR:/backup" \
  alpine:3.19 \
  tar czf /backup/caddy_config.tar.gz -C /data .

# --- Config snapshots ---
cp "$APP_DIR/Caddyfile" "$WORK_DIR/"
cp "$APP_DIR/compose.yaml" "$WORK_DIR/"
cp "$APP_DIR/settings.yml" "$WORK_DIR/"
docker ps --format 'table {{ "{{" }}.Names{{ "}}" }}\t{{ "{{" }}.Image{{ "}}" }}\t{{ "{{" }}.Status{{ "}}" }}' > "$WORK_DIR/containers.txt"

# --- Compress ---
cd "$BACKUP_DIR"
tar czf "${BACKUP_NAME}.tar.gz" "$BACKUP_NAME"
rm -rf "$WORK_DIR"

BACKUP_SIZE=$(ls -lh "$BACKUP_DIR/${BACKUP_NAME}.tar.gz" | awk '{print $5}')
echo "==> Local backup complete: $BACKUP_DIR/${BACKUP_NAME}.tar.gz ($BACKUP_SIZE)"

# --- Remote upload (DO Spaces) ---
if [[ "$REMOTE_STORAGE" == "do-spaces" ]]; then
  echo "==> Uploading to DO Spaces..."
  AWS_ACCESS_KEY_ID="$SPACES_ACCESS_KEY" \
  AWS_SECRET_ACCESS_KEY="$SPACES_SECRET_KEY" \
  aws s3 cp "$BACKUP_DIR/${BACKUP_NAME}.tar.gz" \
    "s3://${SPACES_BUCKET}/{{ project_name }}/" \
    --endpoint-url "https://${SPACES_REGION}.digitaloceanspaces.com" \
    --quiet
  echo "==> Uploaded to s3://${SPACES_BUCKET}/{{ project_name }}/"
fi

# --- Retention ---
echo "==> Applying retention (daily 30d)..."
find "$BACKUP_DIR" -maxdepth 1 -name "*.tar.gz" -mtime +30 -delete
echo "==> Retention cleanup complete"
