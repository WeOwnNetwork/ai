# {{ project_name }} - Docker Compose (ADR-006: In-Container Infisical Injection)
# SearXNG private search engine with Valkey cache and Caddy reverse proxy
# Secrets are fetched IN-PROCESS by the container at startup via `infisical run` entrypoint.
# A `docker restart` re-fetches secrets (bounce-to-refresh). No secrets in environment: block.
# No secrets should be stored in this file or in .env files on disk.
#
# Required Infisical secrets:
#   SEARXNG_SECRET

services:
  searxng:
    image: {{ searxng_image }}
    restart: unless-stopped
    depends_on:
      valkey:
        condition: service_healthy
    # ADR-006: infisical run as container entrypoint — secrets fetched in-process
    entrypoint: ["/usr/bin/infisical", "run", "--projectId={{ infisical_project_id }}", "--env={{ infisical_env }}", "--"]
    environment:
      # Non-secret config only; SEARXNG_SECRET fetched by entrypoint
      SEARXNG_SETTINGS_PATH: /etc/searxng/settings.yml
      INSTANCE_NAME: {{ project_name }}
    volumes:
      - searxng_config:/etc/searxng:rw
      - ./settings.yml:/etc/searxng/settings.yml:ro
      # ADR-006: bind-mount Infisical CLI + auth file (read-only)
      - /usr/bin/infisical:/usr/bin/infisical:ro
      - /opt/{{ project_name | replace('-', '_') }}/.infisical-auth.env.container:/.infisical-auth.env:ro
    networks:
      - searxngnet
    healthcheck:
      test: ["CMD-SHELL", "wget -q --spider http://localhost:8080/healthz || exit 1"]
      start_period: 15s
      interval: 10s
      timeout: 5s
      retries: 3
    deploy:
      resources:
        limits:
          memory: 512M
        reservations:
          memory: 256M

  valkey:
    image: {{ valkey_image }}
    restart: unless-stopped
    command: valkey-server --save 60 1 --loglevel warning
    volumes:
      - valkey_data:/data
    networks:
      - searxngnet
    healthcheck:
      test: ["CMD-SHELL", "valkey-cli ping | grep -q PONG"]
      start_period: 10s
      interval: 10s
      timeout: 5s
      retries: 3
    deploy:
      resources:
        limits:
          memory: 256M
        reservations:
          memory: 128M

  caddy:
    image: {{ caddy_image }}
    restart: unless-stopped
    depends_on:
      searxng:
        condition: service_healthy
    environment:
      DOMAIN: {{ domain }}
    ports:
      - "80:80"
      - "443:443"
      - "443:443/udp"
    volumes:
      - ./Caddyfile:/etc/caddy/Caddyfile:ro
      - caddy_data:/data
      - caddy_config:/config
      # Bind-mount access logs to host so otel-agent's filelog/caddy receiver
      # (mounts /var/log host-side) can read them, and so logs survive container
      # recreation.
      - /var/log/caddy:/var/log/caddy
    networks:
      - searxngnet
    healthcheck:
      test: ["CMD-SHELL", "wget -q --spider http://localhost:80 || exit 1"]
      start_period: 15s
      interval: 15s
      timeout: 5s
      retries: 3
    deploy:
      resources:
        limits:
          memory: 256M
        reservations:
          memory: 128M

volumes:
  searxng_config:
    name: {{ project_name | replace('-', '_') }}_searxng_config
  valkey_data:
    name: {{ project_name | replace('-', '_') }}_valkey_data
  caddy_data:
    name: {{ project_name | replace('-', '_') }}_caddy_data
  caddy_config:
    name: {{ project_name | replace('-', '_') }}_caddy_config

networks:
  searxngnet:
    name: {{ project_name | replace('-', '_') }}_net
    driver: bridge
