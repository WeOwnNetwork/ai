# {{ project_name }} - Terraform Variables
# Managed by OpenTofu
#
# SECURITY NOTE: No application secrets (JWT keys, API tokens, etc.)
# are stored in terraform.tfvars. All application secrets live in Infisical and
# are injected at container runtime via `infisical run`.
# The ONLY sensitive values in tfvars are:
#   - minimus_token     (DigitalOcean API token — required by the DO provider)
#   - ssh_key_fingerprint (public key fingerprint — non-secret identifier)
#   - infisical_client_id / infisical_client_secret (Machine Identity for runtime secret fetch)

# =============================================================================
# Project Identity
# =============================================================================
variable "project_name" {
  description = "Project name (lowercase, hyphens allowed)"
  type        = string
}

variable "domain" {
  description = "Primary domain for the sandbox"
  type        = string
}

# =============================================================================
# DigitalOcean Infrastructure
# =============================================================================
variable "region" {
  description = "DigitalOcean region slug"
  type        = string
  default     = "{{ do_region }}"
}

variable "droplet_size" {
  description = "Droplet size (CPU/RAM) — sandbox requires at least 4 vCPU / 8GB"
  type        = string
  default     = "{{ droplet_size }}"
}

variable "droplet_image" {
  description = "Droplet base image"
  type        = string
  default     = "ubuntu-24-04-x64"
}

variable "ssh_key_fingerprint" {
  description = "SSH key fingerprint for droplet access (non-secret public identifier)"
  type        = string
}

variable "minimus_token" {
  description = "DigitalOcean API token for the DO provider (Custom Scopes: Droplet, Reserved IP, Firewall, Tag, Monitoring)"
  type        = string
  sensitive   = true
}

# =============================================================================
# Container Images
# =============================================================================
variable "sandbox_image" {
  description = "AIO Sandbox Docker image"
  type        = string
  default     = "{{ sandbox_image }}"
}

variable "caddy_image" {
  description = "Caddy Docker image"
  type        = string
  default     = "{{ caddy_image }}"
}

# =============================================================================
# Sandbox Configuration
# =============================================================================
variable "sandbox_workspace" {
  description = "Default workspace path inside the sandbox container"
  type        = string
  default     = "{{ sandbox_workspace }}"
}

variable "sandbox_timezone" {
  description = "Timezone for the sandbox container"
  type        = string
  default     = "{{ sandbox_timezone }}"
}

variable "sandbox_display_width" {
  description = "VNC display width in pixels"
  type        = number
  default     = {{ sandbox_display_width }}
}

variable "sandbox_display_height" {
  description = "VNC display height in pixels"
  type        = number
  default     = {{ sandbox_display_height }}
}

variable "sandbox_homepage" {
  description = "Browser homepage URL inside the sandbox"
  type        = string
  default     = "{{ sandbox_homepage }}"
}

variable "enable_jupyter" {
  description = "Enable Jupyter Notebook server"
  type        = bool
  default     = {{ enable_jupyter | lower }}
}

variable "enable_code_server" {
  description = "Enable VSCode Server (code-server)"
  type        = bool
  default     = {{ enable_code_server | lower }}
}

# =============================================================================
# Infisical Machine Identity (runtime secret injection)
# =============================================================================
variable "infisical_client_id" {
  description = "Infisical Machine Identity Client ID (grants droplet access to fetch secrets)"
  type        = string
  sensitive   = true
}

variable "infisical_client_secret" {
  description = "Infisical Machine Identity Client Secret (shown once at creation in Infisical dashboard)"
  type        = string
  sensitive   = true
}

variable "infisical_project_id" {
  description = "Infisical project ID containing this deployment's secrets"
  type        = string
}

variable "infisical_environment" {
  description = "Infisical environment slug (e.g., prod, staging)"
  type        = string
  default     = "prod"
}

# =============================================================================
# Skinny Backup Configuration
# =============================================================================
variable "enable_skinny_backups" {
  description = "Enable volume-based skinny backups (replaces DO automated backups)"
  type        = bool
  default     = {{ enable_skinny_backups | lower }}
}

variable "backup_remote_storage" {
  description = "Remote storage target for backup offloading"
  type        = string
  default     = "{{ backup_remote_storage }}"
}

variable "backup_do_spaces_bucket" {
  description = "DO Spaces bucket name for remote backups"
  type        = string
  default     = "{{ backup_do_spaces_bucket }}"
}

variable "backup_do_spaces_region" {
  description = "DO Spaces region slug"
  type        = string
  default     = "{{ backup_do_spaces_region }}"
}

# =============================================================================
# Monitoring
# =============================================================================
variable "enable_monitoring" {
  description = "Enable DigitalOcean monitoring alerts"
  type        = bool
  default     = {{ enable_monitoring | lower }}
}

variable "alert_email" {
  description = "Email for monitoring alerts"
  type        = string
  default     = "{{ alert_email }}"
}

variable "cpu_alert_threshold" {
  description = "CPU usage alert threshold (%)"
  type        = number
  default     = {{ cpu_alert_threshold }}
}

variable "memory_alert_threshold" {
  description = "Memory usage alert threshold (%)"
  type        = number
  default     = {{ memory_alert_threshold }}
}

variable "disk_alert_threshold" {
  description = "Disk usage alert threshold (%)"
  type        = number
  default     = 85
}
