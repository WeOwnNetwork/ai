# {{ project_name }} - Main Infrastructure
# Managed by OpenTofu

resource "digitalocean_droplet" "sandbox" {
  name       = "{{ project_name }}"
  image      = var.droplet_image
  size       = var.droplet_size
  region     = var.region
  monitoring = true
  backups    = var.enable_skinny_backups ? false : true

  ssh_keys = [var.ssh_key_fingerprint]

  user_data = templatefile("${path.module}/templates/cloud-init.yaml", {
    project_name            = "{{ project_name | replace('-', '') }}"
    domain                  = var.domain
    sandbox_image           = var.sandbox_image
    caddy_image             = var.caddy_image
    sandbox_workspace       = var.sandbox_workspace
    sandbox_timezone        = var.sandbox_timezone
    sandbox_display_width   = var.sandbox_display_width
    sandbox_display_height  = var.sandbox_display_height
    sandbox_homepage        = var.sandbox_homepage
    enable_jupyter          = var.enable_jupyter
    enable_code_server      = var.enable_code_server
    infisical_client_id     = var.infisical_client_id
    infisical_client_secret = var.infisical_client_secret
    infisical_project_id    = var.infisical_project_id
    infisical_environment   = var.infisical_environment
    enable_skinny_backups   = var.enable_skinny_backups
    backup_remote_storage   = var.backup_remote_storage
    backup_do_spaces_bucket = var.backup_do_spaces_bucket
    backup_do_spaces_region = var.backup_do_spaces_region
  })

  tags = ["{{ project_name }}", "sandbox", "agent", "weown-ai"]

  lifecycle {
    ignore_changes = [user_data]
  }
}

resource "digitalocean_reserved_ip" "sandbox" {
  region = var.region
}

resource "digitalocean_reserved_ip_assignment" "sandbox" {
  ip_address = digitalocean_reserved_ip.sandbox.ip_address
  droplet_id = digitalocean_droplet.sandbox.id
}

resource "digitalocean_firewall" "sandbox" {
  name        = "{{ project_name }}-fw"
  droplet_ids = [digitalocean_droplet.sandbox.id]

  # SSH
  inbound_rule {
    protocol         = "tcp"
    port_range       = "22"
    source_addresses = ["0.0.0.0/0", "::/0"]
  }

  # HTTP (for ACME challenges and redirects)
  inbound_rule {
    protocol         = "tcp"
    port_range       = "80"
    source_addresses = ["0.0.0.0/0", "::/0"]
  }

  # HTTPS
  inbound_rule {
    protocol         = "tcp"
    port_range       = "443"
    source_addresses = ["0.0.0.0/0", "::/0"]
  }

  # HTTPS/QUIC (HTTP/3)
  inbound_rule {
    protocol         = "udp"
    port_range       = "443"
    source_addresses = ["0.0.0.0/0", "::/0"]
  }

  # All outbound TCP
  outbound_rule {
    protocol              = "tcp"
    port_range            = "1-65535"
    destination_addresses = ["0.0.0.0/0", "::/0"]
  }

  # All outbound UDP
  outbound_rule {
    protocol              = "udp"
    port_range            = "1-65535"
    destination_addresses = ["0.0.0.0/0", "::/0"]
  }

  tags = ["{{ project_name }}"]
}
