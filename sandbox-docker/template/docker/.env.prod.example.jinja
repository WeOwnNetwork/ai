# {{ project_name }} - Production Environment Variables EXAMPLE
#
# WARNING: This is an EXAMPLE file. NEVER write real secrets to disk.
# Production secrets (JWT_PUBLIC_KEY, GITHUB_TOKEN, PROXY_SERVER) are
# injected at container startup via `infisical run` and never persisted.
# The only credential on disk is the Infisical Machine Identity at
# /etc/{{ project_name | replace('-', '_') }}/.infisical-auth.env (0600 root,
# rotated on first boot via rotate-bootstrap-secret.sh — see Layer 2 in
# docs/INFRA_BOOTSTRAP_PATTERN.md).

# Domain (non-sensitive)
DOMAIN={{ domain }}

# Container Images (non-sensitive)
SANDBOX_IMAGE={{ sandbox_image }}
CADDY_IMAGE={{ caddy_image }}

# Sandbox Configuration (non-sensitive)
WORKSPACE={{ sandbox_workspace }}
TZ={{ sandbox_timezone }}
DISPLAY_WIDTH={{ sandbox_display_width }}
DISPLAY_HEIGHT={{ sandbox_display_height }}
HOMEPAGE={{ sandbox_homepage }}

# Application secrets — DO NOT put real values here. They are injected at
# container startup via `infisical run -- docker compose up -d` and live
# in the Infisical project, not on disk.
#   JWT_PUBLIC_KEY    (required)  Sandbox API auth
#   GITHUB_TOKEN      (optional)  GitHub access inside sandbox
#   PROXY_SERVER      (optional)  HTTP proxy for outbound traffic

# Infisical environment selector (used by `infisical run --env=...`).
# Machine Identity client_id/client_secret are NOT here — they live in
# /etc/{{ project_name | replace('-', '_') }}/.infisical-auth.env.
INFISICAL_PROJECT_ID={{ infisical_project_id | default('') }}
INFISICAL_ENVIRONMENT={{ infisical_environment | default('prod') }}
