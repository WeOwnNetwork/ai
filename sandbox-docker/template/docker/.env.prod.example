# {{ project_name }} - Production Environment Variables
# Never commit .env.prod with real values
# Use Infisical to manage production secrets

# Domain
DOMAIN={{ domain }}

# Container Images
SANDBOX_IMAGE={{ sandbox_image }}
CADDY_IMAGE=reg.mini.dev/caddy:2

# Sandbox Configuration
WORKSPACE={{ sandbox_workspace }}
TZ={{ sandbox_timezone }}
DISPLAY_WIDTH={{ sandbox_display_width }}
DISPLAY_HEIGHT={{ sandbox_display_height }}
HOMEPAGE={{ sandbox_homepage }}

# Secrets (injected by Infisical at runtime)
JWT_PUBLIC_KEY=<GET_FROM_INFISICAL>
GITHUB_TOKEN=<GET_FROM_INFISICAL>

# Infisical
ENABLE_INFISICAL=true
INFISICAL_TOKEN=<GET_FROM_INFISICAL>
INFISICAL_PROJECT_ID=<GET_FROM_INFISICAL>
INFISICAL_ENVIRONMENT=prod
